# ===============================================================
# fabriq studio — .gitignore
# ===============================================================

# ---------------------------------------------------------------
# [共通] ツール・AI 設定
# ---------------------------------------------------------------
.claude/

# ---------------------------------------------------------------
# [dev_fabriq] fabriq フレームワーク本体（ローカル参照のみ）
# ---------------------------------------------------------------
/dev_fabriq/

# ---------------------------------------------------------------
# [C# / .NET] FabriqStudio WPF プロジェクト
# ---------------------------------------------------------------

# ビルド成果物（必須）
**/bin/
**/obj/

# Visual Studio ローカル設定（コミット不要）
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# JetBrains Rider
.idea/
*.DotSettings.user
_ReSharperCache/

# NuGet（SDK-style では packages/ は使わないが念のため）
**/packages/
*.nupkg

# ---------------------------------------------------------------
# [共通] OS・エディタ生成ファイル
# ---------------------------------------------------------------
*.tmp
*.log
Thumbs.db
desktop.ini
.DS_Store

# ---------------------------------------------------------------
# [dev_fabriq] fabriq 固有の除外（元の設定を維持）
# ---------------------------------------------------------------
/modules/standard/printer_driver_config/INF/*
!/modules/standard/printer_driver_config/INF/命名規則.txt
!/modules/standard/printer_driver_config/INF/.gitkeep

/evidence/export_history/*
!/evidence/export_history/.gitkeep

/evidence/gyotaku/*
!/evidence/gyotaku/.gitkeep

/logs/*
!/logs/.gitkeep

/logs/history/*
!/logs/history
!/logs/history/.gitkeep

**/template/

# 巨大なバイナリ（インストーラー・ドライバー等）
*.iso
*.msi