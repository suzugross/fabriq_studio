<UserControl x:Class="FabriqStudio.Views.BasicParamsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <!-- セクションヘッダー用スタイル -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#2D2D30" />
            <Setter Property="Margin"     Value="0,0,0,2" />
        </Style>

        <!-- サブラベル（ファイルパス表示）用スタイル -->
        <Style x:Key="PathLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10" />
            <Setter Property="Foreground" Value="#888888" />
            <Setter Property="Margin"     Value="0,0,0,8" />
        </Style>

        <!-- 保存ボタン -->
        <Style x:Key="SaveButtonStyle" TargetType="Button">
            <Setter Property="Padding"     Value="16,6" />
            <Setter Property="FontSize"    Value="12" />
            <Setter Property="Background"  Value="#007ACC" />
            <Setter Property="Foreground"  Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor"      Value="Hand" />
        </Style>

        <!-- セクション境界線 -->
        <Style x:Key="SectionBorderStyle" TargetType="Border">
            <Setter Property="Background"       Value="White" />
            <Setter Property="BorderBrush"      Value="#E0E0E0" />
            <Setter Property="BorderThickness"  Value="1" />
            <Setter Property="CornerRadius"     Value="4" />
            <Setter Property="Padding"          Value="16" />
            <Setter Property="Margin"           Value="0,0,0,12" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Background="#F3F3F3">
        <StackPanel Margin="20">

            <!-- ===== ページタイトル ===== -->
            <TextBlock Text="基本パラメータ"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#2D2D30"
                       Margin="0,0,0,16" />

            <!-- ===== プロファイル選択 ===== -->
            <Border Style="{StaticResource SectionBorderStyle}">
                <StackPanel>
                    <TextBlock Text="プロファイル選択"
                               Style="{StaticResource SectionHeaderStyle}" />
                    <TextBlock Text="profiles/ ディレクトリ直下の .csv ファイル"
                               Style="{StaticResource PathLabelStyle}" />

                    <!-- エラー -->
                    <TextBlock Text="{Binding ProfilesError}"
                               Foreground="Red" Margin="0,0,0,6"
                               Visibility="{Binding ProfilesError,
                                   Converter={StaticResource NullToCollapsedConverter}}" />

                    <!-- ローディング -->
                    <TextBlock Text="読み込み中..."
                               Foreground="#888888" Margin="0,0,0,6"
                               Visibility="{Binding IsProfilesLoading,
                                   Converter={StaticResource BoolToVisibilityConverter}}" />

                    <!-- プロファイル選択 ComboBox -->
                    <DockPanel LastChildFill="False" Margin="0,0,0,12">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="実行プロファイル:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" FontSize="13" />
                        <ComboBox DockPanel.Dock="Left"
                                  Width="220"
                                  ItemsSource="{Binding Profiles}"
                                  SelectedItem="{Binding SelectedProfile}"
                                  DisplayMemberPath="Name" />
                    </DockPanel>

                    <!-- モジュールリスト サブヘッダー -->
                    <TextBlock Text="モジュール構成"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#555555"
                               Margin="0,0,0,4" />

                    <!-- モジュール エラー -->
                    <TextBlock Text="{Binding ModulesError}"
                               Foreground="Red" Margin="0,0,0,6"
                               Visibility="{Binding ModulesError,
                                   Converter={StaticResource NullToCollapsedConverter}}" />

                    <!-- モジュール ローディング -->
                    <TextBlock Text="読み込み中..."
                               Foreground="#888888" Margin="0,0,0,6"
                               Visibility="{Binding IsModulesLoading,
                                   Converter={StaticResource BoolToVisibilityConverter}}" />

                    <!-- モジュールリスト DataGrid（読み取り専用）
                         __RESTART__ 等のシステムコマンド行はイタリックで識別表示 -->
                    <DataGrid ItemsSource="{Binding ProfileModules}"
                              IsReadOnly="True"
                              AutoGenerateColumns="False"
                              CanUserReorderColumns="False"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="False"
                              GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="#F7F7F7"
                              BorderBrush="#DDDDDD" BorderThickness="1"
                              MaxHeight="240">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <!-- システムコマンド行（__RESTART__ 等）を区別表示 -->
                                    <DataTrigger Binding="{Binding IsSystemCommand}" Value="True">
                                        <Setter Property="Background" Value="#EEF0FF" />
                                        <Setter Property="FontStyle"  Value="Italic" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="順序"
                                                Binding="{Binding Order}"
                                                Width="55" />
                            <DataGridTextColumn Header="有効"
                                                Binding="{Binding Enabled}"
                                                Width="50" />
                            <DataGridTextColumn Header="スクリプト / コマンド"
                                                Binding="{Binding ScriptPath}"
                                                Width="*" />
                            <DataGridTextColumn Header="説明"
                                                Binding="{Binding Description}"
                                                Width="200" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- ===== 作業者管理 ===== -->
            <Border Style="{StaticResource SectionBorderStyle}">
                <StackPanel>
                    <DockPanel LastChildFill="False" Margin="0,0,0,2">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="作業者管理"
                                   Style="{StaticResource SectionHeaderStyle}" />

                        <!-- 右: ロックトグル -->
                        <ToggleButton DockPanel.Dock="Right"
                                      IsChecked="{Binding IsWorkersLocked}"
                                      Padding="8,3" FontSize="11" Cursor="Hand">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="Content" Value="🔒 ロック中" />
                                    <Style.Triggers>
                                        <Trigger Property="IsChecked" Value="False">
                                            <Setter Property="Content" Value="✏️ 編集中" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>

                        <!-- 右: 未保存インジケーター -->
                        <TextBlock DockPanel.Dock="Right"
                                   Text="● 未保存"
                                   Foreground="OrangeRed" FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   Visibility="{Binding IsWorkersDirty,
                                       Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!-- 右: 保存ステータス -->
                        <TextBlock DockPanel.Dock="Right"
                                   Text="{Binding WorkersSaveStatus}"
                                   Foreground="#107C10" FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   Visibility="{Binding WorkersSaveStatus,
                                       Converter={StaticResource NullToCollapsedConverter}}" />
                    </DockPanel>
                    <TextBlock Text="kernel/csv/workers.csv"
                               Style="{StaticResource PathLabelStyle}" />

                    <!-- エラー -->
                    <TextBlock Text="{Binding WorkersError}"
                               Foreground="Red" Margin="0,0,0,6"
                               Visibility="{Binding WorkersError,
                                   Converter={StaticResource NullToCollapsedConverter}}" />

                    <!-- ローディング -->
                    <TextBlock Text="読み込み中..."
                               Foreground="#888888" Margin="0,0,0,6"
                               Visibility="{Binding IsWorkersLoading,
                                   Converter={StaticResource BoolToVisibilityConverter}}" />

                    <!-- DataGrid: IsReadOnly / CanUserAddRows / CanUserDeleteRows をロックに連動 -->
                    <DataGrid ItemsSource="{Binding Workers}"
                              IsReadOnly="{Binding IsWorkersLocked}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="{Binding IsWorkersEditable}"
                              CanUserDeleteRows="{Binding IsWorkersEditable}"
                              CanUserReorderColumns="False"
                              CanUserResizeColumns="True"
                              GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="#F7F7F7"
                              BorderBrush="#DDDDDD" BorderThickness="1"
                              MaxHeight="220"
                              Margin="0,0,0,8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"   Binding="{Binding ID}"   Width="100" />
                            <DataGridTextColumn Header="氏名" Binding="{Binding Name}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button Content="💾  保存"
                            Style="{StaticResource SaveButtonStyle}"
                            HorizontalAlignment="Right"
                            Command="{Binding SaveWorkersCommand}" />
                </StackPanel>
            </Border>

            <!-- ===== ログ出力先管理 ===== -->
            <Border Style="{StaticResource SectionBorderStyle}">
                <StackPanel>
                    <DockPanel LastChildFill="False" Margin="0,0,0,2">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="ログ出力先管理"
                                   Style="{StaticResource SectionHeaderStyle}" />

                        <!-- 右: ロックトグル -->
                        <ToggleButton DockPanel.Dock="Right"
                                      IsChecked="{Binding IsLogDestLocked}"
                                      Padding="8,3" FontSize="11" Cursor="Hand">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="Content" Value="🔒 ロック中" />
                                    <Style.Triggers>
                                        <Trigger Property="IsChecked" Value="False">
                                            <Setter Property="Content" Value="✏️ 編集中" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>

                        <!-- 右: 未保存インジケーター -->
                        <TextBlock DockPanel.Dock="Right"
                                   Text="● 未保存"
                                   Foreground="OrangeRed" FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   Visibility="{Binding IsLogDestDirty,
                                       Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!-- 右: 保存ステータス -->
                        <TextBlock DockPanel.Dock="Right"
                                   Text="{Binding LogDestSaveStatus}"
                                   Foreground="#107C10" FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   Visibility="{Binding LogDestSaveStatus,
                                       Converter={StaticResource NullToCollapsedConverter}}" />
                    </DockPanel>
                    <TextBlock Text="kernel/csv/log_destinations.csv"
                               Style="{StaticResource PathLabelStyle}" />

                    <!-- Enabled の説明 -->
                    <TextBlock Text="※ 有効フィールド: 1 = 有効、0 = 無効"
                               FontSize="10" Foreground="#888888"
                               Margin="0,0,0,6" />

                    <!-- エラー -->
                    <TextBlock Text="{Binding LogDestError}"
                               Foreground="Red" Margin="0,0,0,6"
                               Visibility="{Binding LogDestError,
                                   Converter={StaticResource NullToCollapsedConverter}}" />

                    <!-- ローディング -->
                    <TextBlock Text="読み込み中..."
                               Foreground="#888888" Margin="0,0,0,6"
                               Visibility="{Binding IsLogDestLoading,
                                   Converter={StaticResource BoolToVisibilityConverter}}" />

                    <!-- DataGrid: IsReadOnly / CanUserAddRows / CanUserDeleteRows をロックに連動 -->
                    <DataGrid ItemsSource="{Binding LogDestinations}"
                              IsReadOnly="{Binding IsLogDestLocked}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="{Binding IsLogDestEditable}"
                              CanUserDeleteRows="{Binding IsLogDestEditable}"
                              CanUserReorderColumns="False"
                              CanUserResizeColumns="True"
                              GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="#F7F7F7"
                              BorderBrush="#DDDDDD" BorderThickness="1"
                              MaxHeight="200"
                              Margin="0,0,0,8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="パス"       Binding="{Binding Path}"        Width="*" />
                            <DataGridTextColumn Header="種別"       Binding="{Binding Type}"        Width="80" />
                            <DataGridTextColumn Header="有効(0/1)" Binding="{Binding Enabled}"     Width="75" />
                            <DataGridTextColumn Header="説明"       Binding="{Binding Description}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button Content="💾  保存"
                            Style="{StaticResource SaveButtonStyle}"
                            HorizontalAlignment="Right"
                            Command="{Binding SaveLogDestCommand}" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
