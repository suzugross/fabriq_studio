<Window x:Class="FabriqStudio.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="fabriq studio"
        Height="700" Width="1100"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- ナビゲーションボタンのスタイル -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background"               Value="Transparent" />
            <Setter Property="Foreground"               Value="#BBBBBB" />
            <Setter Property="BorderThickness"          Value="0" />
            <Setter Property="Height"                   Value="44" />
            <Setter Property="FontSize"                 Value="13" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding"                  Value="16,0,0,0" />
            <Setter Property="Cursor"                   Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#3E3E42" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#007ACC" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <!-- 非活性時: 文字をグレーアウトしカーソルをデフォルトに戻す -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#444444" />
                                <Setter Property="Cursor"     Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- アプリ子項目ボタン: NavButtonStyle よりインデント深め・フォント小さめ -->
        <Style x:Key="NavChildButtonStyle" TargetType="Button"
               BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Padding" Value="32,0,0,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Height"   Value="38" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ===== 左ペイン: ナビゲーション ===== -->
        <Border Grid.Column="0" Background="#252526">
            <DockPanel>

                <!-- アプリタイトル -->
                <Border DockPanel.Dock="Top"
                        Background="#1E1E1E"
                        Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="fabriq studio"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="#FFFFFF" />
                        <TextBlock Text="管理ツール v0.1"
                                   FontSize="10" Foreground="#888888"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

                <!-- ワークスペース情報バー (開いている場合のみ表示) -->
                <Border DockPanel.Dock="Top"
                        Background="#1A1A1A"
                        Padding="12,7"
                        BorderThickness="0,1,0,1"
                        BorderBrush="#333333"
                        Visibility="{Binding IsWorkspaceOpen,
                                     Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="ワークスペース"
                                       FontSize="9" Foreground="#555555" />
                            <TextBlock Text="{Binding WorkspaceName}"
                                       FontSize="11" Foreground="#AAAAAA"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <!-- 最新の情報に更新 -->
                        <Button Grid.Column="1"
                                Content="更新"
                                Command="{Binding ReloadWorkspaceCommand}"
                                ToolTip="最新の情報に更新（未保存の内容は破棄されます）">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd"
                                                        Background="Transparent"
                                                        Padding="{TemplateBinding Padding}"
                                                        CornerRadius="3">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#3E3E42" />
                                                        <Setter Property="Foreground" Value="#CCCCCC" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="FontSize"   Value="10" />
                                    <Setter Property="Foreground" Value="#666666" />
                                    <Setter Property="Cursor"     Value="Hand" />
                                    <Setter Property="Padding"    Value="6,2" />
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- ワークスペースを閉じる -->
                        <Button Grid.Column="2"
                                Content="閉じる"
                                Command="{Binding CloseWorkspaceCommand}"
                                Margin="4,0,0,0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd"
                                                        Background="Transparent"
                                                        Padding="{TemplateBinding Padding}"
                                                        CornerRadius="3">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#3E3E42" />
                                                        <Setter Property="Foreground" Value="#CCCCCC" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="FontSize"   Value="10" />
                                    <Setter Property="Foreground" Value="#666666" />
                                    <Setter Property="Cursor"     Value="Hand" />
                                    <Setter Property="Padding"    Value="6,2" />
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <!-- 新規作成エリア（ワークスペース未設定時のみ表示）-->
                <Border DockPanel.Dock="Top"
                        Background="#1A1A1A"
                        Padding="12,8"
                        BorderThickness="0,0,0,1"
                        BorderBrush="#333333"
                        Visibility="{Binding IsWorkspaceOpen,
                                     Converter={StaticResource BoolToCollapsedConverter}}">
                    <Button Content="📋  テンプレートから新規作成"
                            Command="{Binding CreateNewWorkspaceCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd"
                                                    Background="Transparent"
                                                    Padding="{TemplateBinding Padding}"
                                                    CornerRadius="3">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#3E3E42" />
                                                    <Setter Property="Foreground" Value="#FFFFFF" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="FontSize"   Value="12" />
                                <Setter Property="Foreground" Value="#888888" />
                                <Setter Property="Cursor"     Value="Hand" />
                                <Setter Property="Padding"    Value="4,6" />
                                <Setter Property="HorizontalAlignment" Value="Left" />
                            </Style>
                        </Button.Style>
                    </Button>
                </Border>

                <!-- セクションラベル -->
                <TextBlock DockPanel.Dock="Top"
                           Text="メニュー"
                           FontSize="10" Foreground="#666666"
                           Margin="16,16,0,4"
                           FontWeight="SemiBold" />

                <!-- ナビゲーションボタン: メインメニュー -->
                <StackPanel DockPanel.Dock="Top">
                    <Button Content="⚙  基本パラメータ"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="BasicParams"
                            IsEnabled="{Binding IsWorkspaceOpen}" />

                    <Button Content="🧩  モジュール編集"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="ModuleEdit"
                            IsEnabled="{Binding IsWorkspaceOpen}" />

                    <Button Content="🖥  端末一覧"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="HostList"
                            IsEnabled="{Binding IsWorkspaceOpen}" />
                </StackPanel>

                <!-- セクションラベル: アプリ -->
                <TextBlock DockPanel.Dock="Top"
                           Text="アプリ"
                           FontSize="10" Foreground="#666666"
                           Margin="16,16,0,4"
                           FontWeight="SemiBold" />

                <!-- ナビゲーションボタン: アプリ子項目 -->
                <StackPanel DockPanel.Dock="Top">
                    <Button Content="⌨  Autokey レシピ"
                            Style="{StaticResource NavChildButtonStyle}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="AutokeyEditor"
                            IsEnabled="{Binding IsWorkspaceOpen}" />
                    <Button Content="🔁  Script Looper"
                            Style="{StaticResource NavChildButtonStyle}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="LooperEditor"
                            IsEnabled="{Binding IsWorkspaceOpen}" />
                    <Button Content="📷  デジタル魚拓"
                            Style="{StaticResource NavChildButtonStyle}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="GyotaqEditor"
                            IsEnabled="{Binding IsWorkspaceOpen}" />
                    <Button Content="📖  レジストリ辞書"
                            Style="{StaticResource NavChildButtonStyle}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="RegistryCollection" />
                </StackPanel>

                <!-- 下部: パスフレーズ設定 + フッター -->
                <StackPanel DockPanel.Dock="Bottom">
                    <Border Padding="12,8"
                            BorderThickness="0,1,0,0"
                            BorderBrush="#3E3E42">
                        <DockPanel>
                            <Button DockPanel.Dock="Left"
                                    Command="{Binding SetPassphraseCommand}"
                                    Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd"
                                                            Background="Transparent"
                                                            Padding="4,3"
                                                            CornerRadius="3">
                                                        <ContentPresenter />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#3E3E42" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔑" FontSize="12"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="パスフレーズ"
                                               FontSize="11" Foreground="#AAAAAA"
                                               VerticalAlignment="Center"
                                               Margin="6,0,0,0" />
                                </StackPanel>
                            </Button>
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding PassphraseStatus}"
                                       FontSize="10"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Margin="8,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#555555" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PassphraseStatus}" Value="設定済み">
                                                <Setter Property="Foreground" Value="#107C10" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DockPanel>
                    </Border>
                    <Border Padding="16,10"
                            BorderThickness="0,1,0,0"
                            BorderBrush="#3E3E42">
                        <TextBlock Text="fabriq framework"
                                   FontSize="10" Foreground="#555555" />
                    </Border>
                </StackPanel>

                <Grid /><!-- 残余スペースを埋める -->
            </DockPanel>
        </Border>

        <!-- ===== 右ペイン: コンテンツ ===== -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentPage}"
                        Background="White" />
    </Grid>
</Window>
