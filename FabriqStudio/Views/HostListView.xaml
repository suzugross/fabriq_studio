<UserControl x:Class="FabriqStudio.Views.HostListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- タイトル行 -->
        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,4">
            <!-- 左: タイトル -->
            <TextBlock DockPanel.Dock="Left"
                       Text="端末一覧"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#2D2D30"
                       VerticalAlignment="Center" />

            <!-- 左: 未保存インジケーター -->
            <TextBlock DockPanel.Dock="Left"
                       Text="● 未保存"
                       Foreground="OrangeRed" FontSize="11"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"
                       Visibility="{Binding IsDirty,
                           Converter={StaticResource BoolToVisibilityConverter}}" />

            <!-- 左: 保存ステータス -->
            <TextBlock DockPanel.Dock="Left"
                       Text="{Binding SaveStatus}"
                       Foreground="#107C10" FontSize="11"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"
                       Visibility="{Binding SaveStatus,
                           Converter={StaticResource NullToCollapsedConverter}}" />

            <!-- 左: 保存エラー -->
            <TextBlock DockPanel.Dock="Left"
                       Text="{Binding SaveError}"
                       Foreground="Red" FontSize="11"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"
                       Visibility="{Binding SaveError,
                           Converter={StaticResource NullToCollapsedConverter}}" />

            <!-- 右: ロックトグル -->
            <ToggleButton DockPanel.Dock="Right"
                          IsChecked="{Binding IsLocked}"
                          Padding="8,4" FontSize="11" Cursor="Hand">
                <ToggleButton.Style>
                    <Style TargetType="ToggleButton">
                        <Setter Property="Content" Value="🔒 ロック中" />
                        <Style.Triggers>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter Property="Content" Value="✏️ 編集中" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ToggleButton.Style>
            </ToggleButton>

            <!-- 右: 保存ボタン -->
            <Button DockPanel.Dock="Right"
                    Content="💾 保存"
                    Command="{Binding SaveCommand}"
                    Padding="12,4" FontSize="11"
                    Background="#007ACC" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Margin="0,0,8,0" />

            <!-- 右: 削除ボタン -->
            <Button DockPanel.Dock="Right"
                    Content="🗑 端末削除"
                    Command="{Binding DeleteHostCommand}"
                    Padding="12,4" FontSize="11"
                    Background="#D32F2F" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Margin="0,0,8,0" />

            <!-- 右: 追加ボタン -->
            <Button DockPanel.Dock="Right"
                    Content="＋ 端末追加"
                    Command="{Binding AddHostCommand}"
                    Padding="12,4" FontSize="11"
                    Background="#107C10" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Margin="0,0,8,0" />

            <!-- 右: パスラベル -->
            <TextBlock DockPanel.Dock="Right"
                       Text="kernel/csv/hostlist.csv"
                       FontSize="11" Foreground="#888888"
                       VerticalAlignment="Bottom"
                       Margin="0,0,12,0" />
        </DockPanel>

        <!-- エラー表示 -->
        <TextBlock Grid.Row="1"
                   Text="{Binding ErrorMessage}"
                   Foreground="Red"
                   Margin="0,8,0,8"
                   Visibility="{Binding ErrorMessage,
                       Converter={StaticResource NullToCollapsedConverter}}" />

        <!-- ローディング -->
        <TextBlock Grid.Row="1"
                   Text="読み込み中..."
                   Foreground="#888888"
                   Margin="0,8,0,8"
                   Visibility="{Binding IsLoading,
                       Converter={StaticResource BoolToVisibilityConverter}}" />

        <!-- データグリッド（43カラム、先頭3列フリーズ）
             行をダブルクリックで端末詳細へ遷移 -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Hosts}"
                  SelectedItem="{Binding SelectedHost}"
                  IsReadOnly="True"
                  AutoGenerateColumns="False"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  HorizontalScrollBarVisibility="Auto"
                  FrozenColumnCount="3"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F7F7F7"
                  BorderBrush="#DDDDDD" BorderThickness="1"
                  Margin="0,8,0,0">
            <DataGrid.InputBindings>
                <MouseBinding MouseAction="LeftDoubleClick"
                              Command="{Binding ViewDetailCommand}"
                              CommandParameter="{Binding SelectedHost}" />
            </DataGrid.InputBindings>
            <DataGrid.Columns>
                <!-- 基本情報（フリーズ対象 3列） -->
                <DataGridTextColumn Header="AdminID"    Binding="{Binding AdminID}"   Width="70" />
                <DataGridTextColumn Header="旧PC名"     Binding="{Binding OldPCName}" Width="120" />
                <DataGridTextColumn Header="新PC名"     Binding="{Binding NewPCName}" Width="120" />

                <!-- 有線LAN -->
                <DataGridTextColumn Header="EthernetIP"      Binding="{Binding EthernetIP}"      Width="130" />
                <DataGridTextColumn Header="EthernetSubnet"  Binding="{Binding EthernetSubnet}"  Width="130" />
                <DataGridTextColumn Header="EthernetGateway" Binding="{Binding EthernetGateway}" Width="130" />

                <!-- 無線LAN -->
                <DataGridTextColumn Header="WifiIP"      Binding="{Binding WifiIP}"      Width="130" />
                <DataGridTextColumn Header="WifiSubnet"  Binding="{Binding WifiSubnet}"  Width="130" />
                <DataGridTextColumn Header="WifiGateway" Binding="{Binding WifiGateway}" Width="130" />

                <!-- DNS -->
                <DataGridTextColumn Header="DNS1" Binding="{Binding DNS1}" Width="120" />
                <DataGridTextColumn Header="DNS2" Binding="{Binding DNS2}" Width="120" />
                <DataGridTextColumn Header="DNS3" Binding="{Binding DNS3}" Width="120" />
                <DataGridTextColumn Header="DNS4" Binding="{Binding DNS4}" Width="120" />

                <!-- プリンター 1〜10 -->
                <DataGridTextColumn Header="Printer1 Name"   Binding="{Binding Printer1Name}"   Width="160" />
                <DataGridTextColumn Header="Printer1 Driver" Binding="{Binding Printer1Driver}" Width="200" />
                <DataGridTextColumn Header="Printer1 Port"   Binding="{Binding Printer1Port}"   Width="120" />

                <DataGridTextColumn Header="Printer2 Name"   Binding="{Binding Printer2Name}"   Width="160" />
                <DataGridTextColumn Header="Printer2 Driver" Binding="{Binding Printer2Driver}" Width="200" />
                <DataGridTextColumn Header="Printer2 Port"   Binding="{Binding Printer2Port}"   Width="120" />

                <DataGridTextColumn Header="Printer3 Name"   Binding="{Binding Printer3Name}"   Width="160" />
                <DataGridTextColumn Header="Printer3 Driver" Binding="{Binding Printer3Driver}" Width="200" />
                <DataGridTextColumn Header="Printer3 Port"   Binding="{Binding Printer3Port}"   Width="120" />

                <DataGridTextColumn Header="Printer4 Name"   Binding="{Binding Printer4Name}"   Width="160" />
                <DataGridTextColumn Header="Printer4 Driver" Binding="{Binding Printer4Driver}" Width="200" />
                <DataGridTextColumn Header="Printer4 Port"   Binding="{Binding Printer4Port}"   Width="120" />

                <DataGridTextColumn Header="Printer5 Name"   Binding="{Binding Printer5Name}"   Width="160" />
                <DataGridTextColumn Header="Printer5 Driver" Binding="{Binding Printer5Driver}" Width="200" />
                <DataGridTextColumn Header="Printer5 Port"   Binding="{Binding Printer5Port}"   Width="120" />

                <DataGridTextColumn Header="Printer6 Name"   Binding="{Binding Printer6Name}"   Width="160" />
                <DataGridTextColumn Header="Printer6 Driver" Binding="{Binding Printer6Driver}" Width="200" />
                <DataGridTextColumn Header="Printer6 Port"   Binding="{Binding Printer6Port}"   Width="120" />

                <DataGridTextColumn Header="Printer7 Name"   Binding="{Binding Printer7Name}"   Width="160" />
                <DataGridTextColumn Header="Printer7 Driver" Binding="{Binding Printer7Driver}" Width="200" />
                <DataGridTextColumn Header="Printer7 Port"   Binding="{Binding Printer7Port}"   Width="120" />

                <DataGridTextColumn Header="Printer8 Name"   Binding="{Binding Printer8Name}"   Width="160" />
                <DataGridTextColumn Header="Printer8 Driver" Binding="{Binding Printer8Driver}" Width="200" />
                <DataGridTextColumn Header="Printer8 Port"   Binding="{Binding Printer8Port}"   Width="120" />

                <DataGridTextColumn Header="Printer9 Name"   Binding="{Binding Printer9Name}"   Width="160" />
                <DataGridTextColumn Header="Printer9 Driver" Binding="{Binding Printer9Driver}" Width="200" />
                <DataGridTextColumn Header="Printer9 Port"   Binding="{Binding Printer9Port}"   Width="120" />

                <DataGridTextColumn Header="Printer10 Name"   Binding="{Binding Printer10Name}"   Width="160" />
                <DataGridTextColumn Header="Printer10 Driver" Binding="{Binding Printer10Driver}" Width="200" />
                <DataGridTextColumn Header="Printer10 Port"   Binding="{Binding Printer10Port}"   Width="120" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
