<UserControl x:Class="FabriqStudio.Views.ModuleEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- ヘッダー -->
            <RowDefinition Height="*" />     <!-- 2ペイン -->
        </Grid.RowDefinitions>

        <!-- ===== ヘッダー ===== -->
        <StackPanel Grid.Row="0" Margin="16,16,16,8">
            <TextBlock Text="モジュール編集"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#2D2D30"
                       Margin="0,0,0,4" />

            <!-- エラー -->
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="Red"
                       Visibility="{Binding ErrorMessage,
                           Converter={StaticResource NullToCollapsedConverter}}" />

            <!-- ローディング -->
            <TextBlock Text="読み込み中..."
                       Foreground="#888888"
                       Visibility="{Binding IsLoading,
                           Converter={StaticResource BoolToVisibilityConverter}}" />
        </StackPanel>

        <!-- ===== 2ペイン ===== -->
        <Grid Grid.Row="1" Margin="16,0,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" MinWidth="120" />  <!-- カテゴリリスト -->
                <ColumnDefinition Width="6" />                   <!-- スプリッター -->
                <ColumnDefinition Width="*" />                   <!-- モジュールグリッド -->
            </Grid.ColumnDefinitions>

            <!-- ─── 左ペイン: カテゴリ ─── -->
            <Border Grid.Column="0"
                    BorderBrush="#DDDDDD" BorderThickness="1"
                    CornerRadius="4" Background="White">
                <DockPanel>
                    <!-- カテゴリヘッダー -->
                    <Border DockPanel.Dock="Top"
                            Background="#EFEFEF"
                            BorderBrush="#DDDDDD" BorderThickness="0,0,0,1"
                            CornerRadius="4,4,0,0"
                            Padding="8,5">
                        <TextBlock Text="カテゴリ"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#444444" />
                    </Border>

                    <!-- カテゴリ一覧 -->
                    <ListBox ItemsSource="{Binding CategoryNames}"
                             SelectedItem="{Binding SelectedCategoryName}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding"   Value="8,5" />
                                <Setter Property="FontSize"  Value="12" />
                                <Setter Property="Cursor"    Value="Hand" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- ─── スプリッター ─── -->
            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          Cursor="SizeWE" />

            <!-- ─── 右ペイン: モジュールグリッド ─── -->
            <DataGrid Grid.Column="2"
                      ItemsSource="{Binding FilteredModules}"
                      IsReadOnly="True"
                      AutoGenerateColumns="False"
                      CanUserReorderColumns="True"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      GridLinesVisibility="Horizontal"
                      AlternatingRowBackground="#F7F7F7"
                      BorderBrush="#DDDDDD" BorderThickness="1">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="種別"           Binding="{Binding Kind}"       Width="70" />
                    <DataGridTextColumn Header="メニュー名"   Binding="{Binding MenuName}"    Width="200" />
                    <DataGridTextColumn Header="カテゴリ"     Binding="{Binding Category}"    Width="110" />
                    <DataGridTextColumn Header="モジュールdir" Binding="{Binding ModuleDir}"  Width="150" />
                    <DataGridTextColumn Header="スクリプト"   Binding="{Binding Script}"      Width="*" />
                    <DataGridTextColumn Header="順序"         Binding="{Binding Order}"       Width="55" />
                    <DataGridTextColumn Header="有効"         Binding="{Binding Enabled}"     Width="50" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
