<UserControl x:Class="FabriqStudio.Views.RegistryCollectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>

        <!-- フォームラベル -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11" />
            <Setter Property="Foreground" Value="#555555" />
            <Setter Property="Margin"     Value="0,10,0,3" />
        </Style>

        <!-- フォーム入力ボックス -->
        <Style x:Key="FormInput" TargetType="TextBox">
            <Setter Property="FontSize"                  Value="12" />
            <Setter Property="Padding"                   Value="6,5" />
            <Setter Property="BorderBrush"               Value="#CCCCCC" />
            <Setter Property="BorderThickness"           Value="1" />
            <Setter Property="VerticalContentAlignment"  Value="Center" />
        </Style>

        <!-- プライマリボタン（保存・エクスポート） -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="FontSize"        Value="12" />
            <Setter Property="Padding"         Value="16,6" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="3"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#DDDDDD" />
                                <Setter Property="Foreground" Value="#999999" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 削除ボタン（アウトライン） -->
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="FontSize"        Value="12" />
            <Setter Property="Padding"         Value="14,5" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="BorderBrush"     Value="#CC3333" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground"      Value="#CC3333" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="3"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FFF0F0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- ヘッダー -->
            <RowDefinition Height="*" />     <!-- 2 ペイン -->
        </Grid.RowDefinitions>

        <!-- ===== ヘッダー ===== -->
        <StackPanel Grid.Row="0" Margin="16,16,16,8">
            <TextBlock Text="レジストリ辞書"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#2D2D30"
                       Margin="0,0,0,2" />
            <TextBlock FontSize="11" Foreground="#888888"
                       Text="レジストリ設定のテンプレートを管理し、ワークスペースの reg_config CSV へエクスポートします。" />
        </StackPanel>

        <!-- ===== 2 ペイン ===== -->
        <Grid Grid.Row="1" Margin="16,0,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="180" />  <!-- 左: 一覧 -->
                <ColumnDefinition Width="6" />                   <!-- スプリッター -->
                <ColumnDefinition Width="*" />                   <!-- 右: 詳細 -->
            </Grid.ColumnDefinitions>

            <!-- ─── 左ペイン: フィルタ + 一覧 ─── -->
            <Border Grid.Column="0"
                    BorderBrush="#DDDDDD" BorderThickness="1"
                    CornerRadius="4" Background="White">
                <DockPanel>

                    <!-- 一覧ヘッダー + 追加ボタン -->
                    <Border DockPanel.Dock="Top"
                            Background="#EFEFEF"
                            BorderBrush="#DDDDDD" BorderThickness="0,0,0,1"
                            CornerRadius="4,4,0,0"
                            Padding="8,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="エントリ一覧"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="#444444"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1"
                                    Content="＋ 追加"
                                    Command="{Binding AddEntryCommand}"
                                    FontSize="11" Cursor="Hand"
                                    Padding="8,3"
                                    Background="#0E7AC6" Foreground="White"
                                    BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" CornerRadius="3"
                                                Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- フィルタ -->
                    <Border DockPanel.Dock="Top"
                            Padding="8,6"
                            BorderBrush="#DDDDDD" BorderThickness="0,0,0,1"
                            Background="#FAFAFA">
                        <StackPanel>
                            <!-- 検索ボックス -->
                            <Grid>
                                <TextBox x:Name="SearchBox"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="12" Padding="6,5"
                                         BorderBrush="#CCCCCC" BorderThickness="1" />
                                <TextBlock Text="検索（タイトル / タグ / KeyName）"
                                           Foreground="#AAAAAA" FontSize="11"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=SearchBox, Path=Text}" Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <!-- カテゴリ + Hive フィルタ -->
                            <Grid Margin="0,5,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="6" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0"
                                          ItemsSource="{Binding CategoryOptions}"
                                          SelectedItem="{Binding CategoryFilter}"
                                          FontSize="11" />
                                <ComboBox Grid.Column="2"
                                          ItemsSource="{Binding HiveOptions}"
                                          SelectedItem="{Binding HiveFilter}"
                                          FontSize="11" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- エントリ一覧 -->
                    <ListBox ItemsSource="{Binding FilteredEntries}"
                             SelectedItem="{Binding SelectedEntry}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="8,6" />
                                <Setter Property="Cursor"  Value="Hand" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock FontSize="10" Foreground="#888888">
                                        <Run Text="{Binding Category, Mode=OneWay}" />
                                        <Run Text=" / " />
                                        <Run Text="{Binding Hive, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </DockPanel>
            </Border>

            <!-- ─── スプリッター ─── -->
            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          Cursor="SizeWE" />

            <!-- ─── 右ペイン: 詳細フォーム ─── -->
            <Border Grid.Column="2"
                    BorderBrush="#DDDDDD" BorderThickness="1"
                    CornerRadius="4" Background="White"
                    ClipToBounds="True">
                <Grid>

                <!-- 未選択時のプレースホルダー -->
                <TextBlock Text="左のリストからエントリを選択するか、「＋ 追加」で新規作成してください。"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="#BBBBBB" FontSize="13" TextWrapping="Wrap"
                           TextAlignment="Center" Margin="32,0"
                           Visibility="{Binding IsEntrySelected,
                               Converter={StaticResource BoolToCollapsedConverter}}" />

                <!-- 詳細フォーム（エントリ選択時） -->
                <DockPanel Visibility="{Binding IsEntrySelected,
                               Converter={StaticResource BoolToVisibilityConverter}}">

                    <!-- アクションバー（下部固定） -->
                    <Border DockPanel.Dock="Bottom"
                            Padding="16,10"
                            BorderBrush="#EEEEEE" BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- 左: 保存 / 削除 -->
                            <StackPanel Grid.Column="0"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Button Content="保存"
                                        Command="{Binding SaveEntryCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Background="#0E7AC6" Foreground="White"
                                        Margin="0,0,8,0" />
                                <Button Content="削除"
                                        Command="{Binding DeleteEntryCommand}"
                                        Style="{StaticResource DangerButton}"
                                        Background="White" />
                            </StackPanel>

                            <!-- 右: ワークスペースへエクスポート -->
                            <Button Grid.Column="1"
                                    Content="▶  ワークスペースへエクスポート"
                                    Command="{Binding ExportToWorkspaceCommand}"
                                    IsEnabled="{Binding IsWorkspaceOpen}"
                                    Style="{StaticResource PrimaryButton}"
                                    Background="#2D7A2D" Foreground="White"
                                    ToolTip="現在開いているワークスペースの reg_config CSV に追記します" />
                        </Grid>
                    </Border>

                    <!-- ステータスメッセージ（下部固定） -->
                    <Border DockPanel.Dock="Bottom"
                            Padding="16,6"
                            Background="#F8F8F8"
                            BorderBrush="#EEEEEE" BorderThickness="0,1,0,0"
                            Visibility="{Binding StatusMessage,
                                Converter={StaticResource NullToCollapsedConverter}}">
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontSize="11" Foreground="#555555" />
                    </Border>

                    <!-- スクロール可能なフォーム本体 -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="20,12,20,16">

                            <!-- タイトル -->
                            <TextBlock Text="タイトル  *" Style="{StaticResource FieldLabel}"
                                       Margin="0,4,0,3" />
                            <TextBox Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormInput}" />

                            <!-- カテゴリ + Hive -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="カテゴリ" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding EditCategory, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FormInput}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Hive" Style="{StaticResource FieldLabel}" />
                                    <ComboBox ItemsSource="{Binding HiveFormOptions}"
                                              SelectedItem="{Binding EditHive}"
                                              FontSize="12" Height="28" />
                                </StackPanel>
                            </Grid>

                            <!-- KeyPath -->
                            <TextBlock Text="KeyPath  *" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding EditKeyPath, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormInput}" />

                            <!-- KeyName + Type + Value -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="110" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="KeyName  *" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding EditKeyName, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FormInput}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="型 (Type)" Style="{StaticResource FieldLabel}" />
                                    <ComboBox ItemsSource="{Binding TypeOptions}"
                                              SelectedItem="{Binding EditType}"
                                              FontSize="12" Height="28" />
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="値 (Value)" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding EditValue, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FormInput}" />
                                </StackPanel>
                            </Grid>

                            <!-- タグ -->
                            <TextBlock Text="タグ（セミコロン区切り）" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding EditTags, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormInput}" />

                            <!-- 説明 -->
                            <TextBlock Text="説明" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding EditDescription, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormInput}"
                                     Height="200"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     VerticalContentAlignment="Top" />

                        </StackPanel>
                    </ScrollViewer>

                </DockPanel>

                </Grid>
            </Border>

        </Grid>
    </Grid>
</UserControl>
