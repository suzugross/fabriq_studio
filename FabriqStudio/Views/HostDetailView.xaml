<UserControl x:Class="FabriqStudio.Views.HostDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <!-- フィールドラベル -->
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Width"             Value="150" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize"          Value="12" />
            <Setter Property="Foreground"        Value="#555555" />
            <Setter Property="Margin"            Value="0,0,8,0" />
        </Style>

        <!-- フィールド入力欄（現在は ReadOnly） -->
        <Style x:Key="FieldBoxStyle" TargetType="TextBox">
            <Setter Property="IsReadOnly"       Value="True" />
            <Setter Property="FontSize"         Value="12" />
            <Setter Property="Padding"          Value="4,3" />
            <Setter Property="BorderBrush"      Value="#CCCCCC" />
            <Setter Property="Background"       Value="#F8F8F8" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <!-- セクション Border -->
        <Style x:Key="SectionBorderStyle" TargetType="Border">
            <Setter Property="Background"      Value="White" />
            <Setter Property="BorderBrush"     Value="#E0E0E0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius"    Value="4" />
            <Setter Property="Padding"         Value="14" />
            <Setter Property="Margin"          Value="0,0,0,10" />
        </Style>

        <!-- セクションヘッダー -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#444444" />
            <Setter Property="Margin"     Value="0,0,0,10" />
        </Style>
    </UserControl.Resources>

    <Grid Background="#F3F3F3">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- ヘッダーバー -->
            <RowDefinition Height="*" />     <!-- コンテンツ -->
        </Grid.RowDefinitions>

        <!-- ===== ヘッダーバー ===== -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                Padding="12,8">
            <DockPanel LastChildFill="False">
                <Button DockPanel.Dock="Left"
                        Content="← 戻る"
                        Command="{Binding NavigateBackCommand}"
                        Padding="12,5" FontSize="12"
                        Background="Transparent" BorderBrush="#AAAAAA"
                        Cursor="Hand" />

                <TextBlock DockPanel.Dock="Left"
                           Text="端末詳細"
                           FontSize="18" FontWeight="Bold"
                           Foreground="#2D2D30"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0" />

                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding Host.AdminID, StringFormat=' [{0}]'}"
                           FontSize="14" Foreground="#007ACC"
                           VerticalAlignment="Center"
                           Margin="4,0,0,0" />
            </DockPanel>
        </Border>

        <!-- ===== 2 カラムコンテンツ ===== -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="320" />  <!-- 基本情報 + ネットワーク -->
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" MinWidth="360" />  <!-- プリンター -->
            </Grid.ColumnDefinitions>

            <!-- ─── 左列: 基本情報・ネットワーク ─── -->
            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- 基本情報 -->
                    <Border Style="{StaticResource SectionBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="基本情報" Style="{StaticResource SectionHeaderStyle}" />
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock DockPanel.Dock="Left" Text="AdminID:"      Style="{StaticResource FieldLabelStyle}" />
                                <TextBox   Text="{Binding Host.AdminID}"              Style="{StaticResource FieldBoxStyle}" />
                            </DockPanel>
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock DockPanel.Dock="Left" Text="旧PC名:"       Style="{StaticResource FieldLabelStyle}" />
                                <TextBox   Text="{Binding Host.OldPCName}"            Style="{StaticResource FieldBoxStyle}" />
                            </DockPanel>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left" Text="新PC名:"       Style="{StaticResource FieldLabelStyle}" />
                                <TextBox   Text="{Binding Host.NewPCName}"            Style="{StaticResource FieldBoxStyle}" />
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- 有線LAN -->
                    <Border Style="{StaticResource SectionBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="有線LAN" Style="{StaticResource SectionHeaderStyle}" />
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock DockPanel.Dock="Left" Text="IPアドレス:"   Style="{StaticResource FieldLabelStyle}" />
                                <TextBox   Text="{Binding Host.EthernetIP}"           Style="{StaticResource FieldBoxStyle}" />
                            </DockPanel>
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock DockPanel.Dock="Left" Text="サブネット:"   Style="{StaticResource FieldLabelStyle}" />
                                <TextBox   Text="{Binding Host.EthernetSubnet}"       Style="{StaticResource FieldBoxStyle}" />
                            </DockPanel>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left" Text="デフォルトGW:" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox   Text="{Binding Host.EthernetGateway}"      Style="{StaticResource FieldBoxStyle}" />
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- 無線LAN -->
                    <Border Style="{StaticResource SectionBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="無線LAN (Wi-Fi)" Style="{StaticResource SectionHeaderStyle}" />
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock DockPanel.Dock="Left" Text="IPアドレス:"   Style="{StaticResource FieldLabelStyle}" />
                                <TextBox   Text="{Binding Host.WifiIP}"               Style="{StaticResource FieldBoxStyle}" />
                            </DockPanel>
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock DockPanel.Dock="Left" Text="サブネット:"   Style="{StaticResource FieldLabelStyle}" />
                                <TextBox   Text="{Binding Host.WifiSubnet}"           Style="{StaticResource FieldBoxStyle}" />
                            </DockPanel>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left" Text="デフォルトGW:" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox   Text="{Binding Host.WifiGateway}"          Style="{StaticResource FieldBoxStyle}" />
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- DNS -->
                    <Border Style="{StaticResource SectionBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="DNS" Style="{StaticResource SectionHeaderStyle}" />
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock DockPanel.Dock="Left" Text="DNS 1:" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox   Text="{Binding Host.DNS1}"          Style="{StaticResource FieldBoxStyle}" />
                            </DockPanel>
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock DockPanel.Dock="Left" Text="DNS 2:" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox   Text="{Binding Host.DNS2}"          Style="{StaticResource FieldBoxStyle}" />
                            </DockPanel>
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock DockPanel.Dock="Left" Text="DNS 3:" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox   Text="{Binding Host.DNS3}"          Style="{StaticResource FieldBoxStyle}" />
                            </DockPanel>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left" Text="DNS 4:" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox   Text="{Binding Host.DNS4}"          Style="{StaticResource FieldBoxStyle}" />
                            </DockPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ─── 右列: プリンター ─── -->
            <Border Grid.Column="2"
                    Style="{StaticResource SectionBorderStyle}"
                    Margin="0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="プリンター（最大10台）"
                               Style="{StaticResource SectionHeaderStyle}" />

                    <DataGrid ItemsSource="{Binding Printers}"
                              IsReadOnly="True"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="False"
                              CanUserResizeColumns="True"
                              GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="#F7F7F7"
                              BorderBrush="#DDDDDD" BorderThickness="1"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="No."    Binding="{Binding Number}" Width="40" />
                            <DataGridTextColumn Header="名前"   Binding="{Binding Name}"   Width="180" />
                            <DataGridTextColumn Header="ドライバー" Binding="{Binding Driver}" Width="*" />
                            <DataGridTextColumn Header="ポート" Binding="{Binding Port}"   Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

        </Grid>
    </Grid>
</UserControl>
