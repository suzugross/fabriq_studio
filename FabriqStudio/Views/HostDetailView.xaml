<UserControl x:Class="FabriqStudio.Views.HostDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:FabriqStudio.Converters">

    <UserControl.Resources>
        <converters:DirtyToForegroundConverter x:Key="DirtyConverter" />

        <!-- 暗号化・復号コンテキストメニュー（x:Shared=False で TextBox ごとに個別インスタンス） -->
        <ContextMenu x:Key="CryptoContextMenu" x:Shared="False">
            <MenuItem Header="暗号化 (ENC:)" Click="EncryptField_Click" />
            <MenuItem Header="復号"          Click="DecryptField_Click" />
            <Separator />
            <MenuItem Header="全フィールド一括暗号化" Click="EncryptAllFields_Click" />
            <MenuItem Header="全フィールド一括復号"   Click="DecryptAllFields_Click" />
        </ContextMenu>

        <!-- フィールドラベル -->
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Width"             Value="150" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize"          Value="12" />
            <Setter Property="Foreground"        Value="#555555" />
            <Setter Property="Margin"            Value="0,0,8,0" />
        </Style>

        <!-- フィールド入力欄: IsReadOnly / Background を IsLocked に連動 -->
        <Style x:Key="FieldBoxStyle" TargetType="TextBox">
            <Setter Property="IsReadOnly"              Value="{Binding IsLocked}" />
            <Setter Property="FontSize"                Value="12" />
            <Setter Property="Padding"                 Value="4,3" />
            <Setter Property="BorderBrush"             Value="#CCCCCC" />
            <Setter Property="Background"              Value="White" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="ContextMenu"             Value="{StaticResource CryptoContextMenu}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLocked}" Value="True">
                    <Setter Property="Background" Value="#F8F8F8" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- セクション Border -->
        <Style x:Key="SectionBorderStyle" TargetType="Border">
            <Setter Property="Background"      Value="White" />
            <Setter Property="BorderBrush"     Value="#E0E0E0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius"    Value="4" />
            <Setter Property="Padding"         Value="14" />
            <Setter Property="Margin"          Value="0,0,0,10" />
        </Style>

        <!-- セクションヘッダー -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#444444" />
            <Setter Property="Margin"     Value="0,0,0,10" />
        </Style>
    </UserControl.Resources>

    <Grid Background="#F3F3F3">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===== ヘッダーバー ===== -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                Padding="12,8">
            <DockPanel LastChildFill="False">

                <!-- 左: 戻る + タイトル -->
                <Button DockPanel.Dock="Left"
                        Content="← 戻る"
                        Command="{Binding NavigateBackCommand}"
                        Padding="12,5" FontSize="12"
                        Background="Transparent" BorderBrush="#AAAAAA"
                        Cursor="Hand" />
                <TextBlock DockPanel.Dock="Left"
                           Text="端末詳細"
                           FontSize="18" FontWeight="Bold"
                           Foreground="#2D2D30"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0" />
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding Host.AdminID, StringFormat=' [{0}]'}"
                           FontSize="14" Foreground="#007ACC"
                           VerticalAlignment="Center"
                           Margin="4,0,0,0" />

                <!-- 右: ロック / 保存ボタン / ステータス / Dirty -->
                <ToggleButton DockPanel.Dock="Right"
                              IsChecked="{Binding IsLocked}"
                              Padding="10,4" FontSize="12" Cursor="Hand"
                              Margin="0,0,0,0">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton">
                            <Setter Property="Content" Value="🔒 ロック中（読み取り専用）" />
                            <Style.Triggers>
                                <Trigger Property="IsChecked" Value="False">
                                    <Setter Property="Content" Value="✏️ 編集中" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>

                <Button DockPanel.Dock="Right"
                        Content="💾 保存"
                        Command="{Binding SaveCommand}"
                        Padding="14,5" FontSize="12"
                        Background="#007ACC" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Margin="0,0,8,0" />

                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding SaveStatus}"
                           Foreground="#107C10" FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"
                           Visibility="{Binding SaveStatus,
                               Converter={StaticResource NullToCollapsedConverter}}" />

                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding SaveError}"
                           Foreground="Red" FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"
                           Visibility="{Binding SaveError,
                               Converter={StaticResource NullToCollapsedConverter}}" />

                <TextBlock DockPanel.Dock="Right"
                           Text="● 未保存の変更があります"
                           Foreground="OrangeRed" FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"
                           Visibility="{Binding IsDirty,
                               Converter={StaticResource BoolToVisibilityConverter}}" />
            </DockPanel>
        </Border>

        <!-- ===== 2 カラムコンテンツ ===== -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="320" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" MinWidth="360" />
            </Grid.ColumnDefinitions>

            <!-- ─── 左列: 基本情報・ネットワーク ─── -->
            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- 基本情報 -->
                    <Border Style="{StaticResource SectionBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="基本情報" Style="{StaticResource SectionHeaderStyle}" />
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock DockPanel.Dock="Left" Text="AdminID:" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Style="{StaticResource FieldBoxStyle}" Tag="AdminID"
                                         Text="{Binding Host.AdminID, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBox.Foreground><MultiBinding Converter="{StaticResource DirtyConverter}"><Binding Path="Host.AdminID" /><Binding Path="OriginalHost.AdminID" /></MultiBinding></TextBox.Foreground>
                                </TextBox>
                            </DockPanel>
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock DockPanel.Dock="Left" Text="旧PC名:" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Style="{StaticResource FieldBoxStyle}" Tag="OldPCName"
                                         Text="{Binding Host.OldPCName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBox.Foreground><MultiBinding Converter="{StaticResource DirtyConverter}"><Binding Path="Host.OldPCName" /><Binding Path="OriginalHost.OldPCName" /></MultiBinding></TextBox.Foreground>
                                </TextBox>
                            </DockPanel>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left" Text="新PC名:" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Style="{StaticResource FieldBoxStyle}" Tag="NewPCName"
                                         Text="{Binding Host.NewPCName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBox.Foreground><MultiBinding Converter="{StaticResource DirtyConverter}"><Binding Path="Host.NewPCName" /><Binding Path="OriginalHost.NewPCName" /></MultiBinding></TextBox.Foreground>
                                </TextBox>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- 有線LAN -->
                    <Border Style="{StaticResource SectionBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="有線LAN" Style="{StaticResource SectionHeaderStyle}" />
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock DockPanel.Dock="Left" Text="IPアドレス:"    Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Style="{StaticResource FieldBoxStyle}" Tag="EthernetIP"
                                         Text="{Binding Host.EthernetIP, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBox.Foreground><MultiBinding Converter="{StaticResource DirtyConverter}"><Binding Path="Host.EthernetIP" /><Binding Path="OriginalHost.EthernetIP" /></MultiBinding></TextBox.Foreground>
                                </TextBox>
                            </DockPanel>
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock DockPanel.Dock="Left" Text="サブネット:"    Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Style="{StaticResource FieldBoxStyle}" Tag="EthernetSubnet"
                                         Text="{Binding Host.EthernetSubnet, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBox.Foreground><MultiBinding Converter="{StaticResource DirtyConverter}"><Binding Path="Host.EthernetSubnet" /><Binding Path="OriginalHost.EthernetSubnet" /></MultiBinding></TextBox.Foreground>
                                </TextBox>
                            </DockPanel>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left" Text="デフォルトGW:" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Style="{StaticResource FieldBoxStyle}" Tag="EthernetGateway"
                                         Text="{Binding Host.EthernetGateway, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBox.Foreground><MultiBinding Converter="{StaticResource DirtyConverter}"><Binding Path="Host.EthernetGateway" /><Binding Path="OriginalHost.EthernetGateway" /></MultiBinding></TextBox.Foreground>
                                </TextBox>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- 無線LAN -->
                    <Border Style="{StaticResource SectionBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="無線LAN (Wi-Fi)" Style="{StaticResource SectionHeaderStyle}" />
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock DockPanel.Dock="Left" Text="IPアドレス:"    Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Style="{StaticResource FieldBoxStyle}" Tag="WifiIP"
                                         Text="{Binding Host.WifiIP, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBox.Foreground><MultiBinding Converter="{StaticResource DirtyConverter}"><Binding Path="Host.WifiIP" /><Binding Path="OriginalHost.WifiIP" /></MultiBinding></TextBox.Foreground>
                                </TextBox>
                            </DockPanel>
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock DockPanel.Dock="Left" Text="サブネット:"    Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Style="{StaticResource FieldBoxStyle}" Tag="WifiSubnet"
                                         Text="{Binding Host.WifiSubnet, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBox.Foreground><MultiBinding Converter="{StaticResource DirtyConverter}"><Binding Path="Host.WifiSubnet" /><Binding Path="OriginalHost.WifiSubnet" /></MultiBinding></TextBox.Foreground>
                                </TextBox>
                            </DockPanel>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left" Text="デフォルトGW:" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Style="{StaticResource FieldBoxStyle}" Tag="WifiGateway"
                                         Text="{Binding Host.WifiGateway, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBox.Foreground><MultiBinding Converter="{StaticResource DirtyConverter}"><Binding Path="Host.WifiGateway" /><Binding Path="OriginalHost.WifiGateway" /></MultiBinding></TextBox.Foreground>
                                </TextBox>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- DNS -->
                    <Border Style="{StaticResource SectionBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="DNS" Style="{StaticResource SectionHeaderStyle}" />
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock DockPanel.Dock="Left" Text="DNS 1:" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Style="{StaticResource FieldBoxStyle}" Tag="DNS1"
                                         Text="{Binding Host.DNS1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBox.Foreground><MultiBinding Converter="{StaticResource DirtyConverter}"><Binding Path="Host.DNS1" /><Binding Path="OriginalHost.DNS1" /></MultiBinding></TextBox.Foreground>
                                </TextBox>
                            </DockPanel>
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock DockPanel.Dock="Left" Text="DNS 2:" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Style="{StaticResource FieldBoxStyle}" Tag="DNS2"
                                         Text="{Binding Host.DNS2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBox.Foreground><MultiBinding Converter="{StaticResource DirtyConverter}"><Binding Path="Host.DNS2" /><Binding Path="OriginalHost.DNS2" /></MultiBinding></TextBox.Foreground>
                                </TextBox>
                            </DockPanel>
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock DockPanel.Dock="Left" Text="DNS 3:" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Style="{StaticResource FieldBoxStyle}" Tag="DNS3"
                                         Text="{Binding Host.DNS3, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBox.Foreground><MultiBinding Converter="{StaticResource DirtyConverter}"><Binding Path="Host.DNS3" /><Binding Path="OriginalHost.DNS3" /></MultiBinding></TextBox.Foreground>
                                </TextBox>
                            </DockPanel>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left" Text="DNS 4:" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Style="{StaticResource FieldBoxStyle}" Tag="DNS4"
                                         Text="{Binding Host.DNS4, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBox.Foreground><MultiBinding Converter="{StaticResource DirtyConverter}"><Binding Path="Host.DNS4" /><Binding Path="OriginalHost.DNS4" /></MultiBinding></TextBox.Foreground>
                                </TextBox>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- BitLocker -->
                    <Border Style="{StaticResource SectionBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="BitLocker" Style="{StaticResource SectionHeaderStyle}" />
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left" Text="PIN:" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Style="{StaticResource FieldBoxStyle}" Tag="Pin"
                                         Text="{Binding Host.Pin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBox.Foreground><MultiBinding Converter="{StaticResource DirtyConverter}"><Binding Path="Host.Pin" /><Binding Path="OriginalHost.Pin" /></MultiBinding></TextBox.Foreground>
                                </TextBox>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ─── 右列: プリンター（表示のみ） ─── -->
            <Border Grid.Column="2"
                    Style="{StaticResource SectionBorderStyle}"
                    Margin="0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="プリンター（最大10台）"
                               Style="{StaticResource SectionHeaderStyle}" />
                    <TextBlock DockPanel.Dock="Top"
                               Text="※ プリンター項目の編集は hostlist.csv を直接編集してください"
                               FontSize="10" Foreground="#AAAAAA"
                               Margin="0,0,0,8" />

                    <DataGrid ItemsSource="{Binding Printers}"
                              IsReadOnly="True"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="False"
                              CanUserResizeColumns="True"
                              GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="#F7F7F7"
                              BorderBrush="#DDDDDD" BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="No."        Binding="{Binding Number}" Width="40" />
                            <DataGridTextColumn Header="名前"       Binding="{Binding Name}"   Width="180" />
                            <DataGridTextColumn Header="ドライバー" Binding="{Binding Driver}" Width="*" />
                            <DataGridTextColumn Header="ポート"     Binding="{Binding Port}"   Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

        </Grid>
    </Grid>
</UserControl>
