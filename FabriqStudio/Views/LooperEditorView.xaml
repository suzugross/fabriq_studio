<UserControl x:Class="FabriqStudio.Views.LooperEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:FabriqStudio.Models">

    <UserControl.InputBindings>
        <!-- Ctrl+E: エクスポート, Delete: 行削除 -->
        <KeyBinding Key="E" Modifiers="Control" Command="{Binding ExportCommand}" />
        <KeyBinding Key="Delete" Command="{Binding DeleteRowCommand}" />
    </UserControl.InputBindings>

    <UserControl.Resources>
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Padding"      Value="12,5" />
            <Setter Property="FontSize"     Value="12" />
            <Setter Property="Cursor"       Value="Hand" />
            <Setter Property="Background"   Value="#F0F0F0" />
            <Setter Property="BorderBrush"  Value="#CCCCCC" />
            <Setter Property="Margin"       Value="0,0,6,0" />
        </Style>
        <Style x:Key="AccentButtonStyle" TargetType="Button"
               BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Background" Value="#007ACC" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style x:Key="DangerButtonStyle" TargetType="Button"
               BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Background" Value="#C85000" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style x:Key="RowOpButtonStyle" TargetType="Button">
            <Setter Property="Padding"      Value="10,4" />
            <Setter Property="FontSize"     Value="11" />
            <Setter Property="Cursor"       Value="Hand" />
            <Setter Property="Background"   Value="#F5F5F5" />
            <Setter Property="BorderBrush"  Value="#CCCCCC" />
            <Setter Property="Margin"       Value="0,0,4,0" />
        </Style>
        <Style x:Key="RefSectionStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#5C2D91" />
            <Setter Property="Margin"     Value="0,10,0,2" />
        </Style>
        <Style x:Key="RefBodyStyle" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="10" />
            <Setter Property="Foreground"   Value="#555555" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin"       Value="4,0,0,0" />
        </Style>
    </UserControl.Resources>

    <Grid Background="#F3F3F3">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- ツールバー -->
            <RowDefinition Height="Auto" />  <!-- モジュール名バー -->
            <RowDefinition Height="*" />     <!-- メインコンテンツ -->
        </Grid.RowDefinitions>

        <!-- ===== ツールバー ===== -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                Padding="10,7">
            <DockPanel LastChildFill="False">

                <!-- 左: 操作ボタン -->
                <Button DockPanel.Dock="Left"
                        Content="📄 新規"
                        Command="{Binding NewCommand}"
                        Style="{StaticResource ToolbarButtonStyle}" />
                <Button DockPanel.Dock="Left"
                        Content="📂 読み込み"
                        Command="{Binding LoadCommand}"
                        Style="{StaticResource ToolbarButtonStyle}" />
                <Button DockPanel.Dock="Left"
                        Content="📤 エクスポート"
                        Command="{Binding ExportCommand}"
                        Style="{StaticResource AccentButtonStyle}" />
                <Button DockPanel.Dock="Left"
                        Content="▶ テスト実行"
                        Command="{Binding TestRunCommand}"
                        Style="{StaticResource DangerButtonStyle}" />

                <!-- 右: ステータス / エラー / Dirty インジケータ -->
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding ErrorMessage}"
                           Foreground="Red" FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"
                           Visibility="{Binding ErrorMessage,
                               Converter={StaticResource NullToCollapsedConverter}}" />
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding StatusMessage}"
                           Foreground="#107C10" FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"
                           Visibility="{Binding StatusMessage,
                               Converter={StaticResource NullToCollapsedConverter}}" />
                <TextBlock DockPanel.Dock="Right"
                           Text="● 未保存の変更があります"
                           Foreground="OrangeRed" FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDirty}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock DockPanel.Dock="Right"
                           Text="実行中..."
                           Foreground="#888888" FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"
                           Visibility="{Binding IsRunning,
                               Converter={StaticResource BoolToVisibilityConverter}}" />
            </DockPanel>
        </Border>

        <!-- ===== モジュール名バー ===== -->
        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                Padding="12,8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="モジュール名:"
                           FontSize="12" FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <TextBlock DockPanel.Dock="Right"
                           Text="（エクスポート時のフォルダ名・メニュー表示名）"
                           FontSize="10" Foreground="#AAAAAA"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0" />
                <TextBox Text="{Binding ModuleName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="13"
                         Padding="6,4"
                         BorderBrush="#CCCCCC"
                         MaxWidth="320"
                         HorizontalAlignment="Left" />
            </DockPanel>
        </Border>

        <!-- ===== メインコンテンツ: DataGrid + リファレンス ===== -->
        <Grid Grid.Row="2" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"   MinWidth="500" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="230" />
            </Grid.ColumnDefinitions>

            <!-- ─── 左: ループ設定 DataGrid ─── -->
            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#E0E0E0" BorderThickness="1"
                    CornerRadius="4" Padding="10">
                <DockPanel>

                    <!-- 行操作ボタン (下部) -->
                    <StackPanel DockPanel.Dock="Bottom"
                                Orientation="Horizontal"
                                Margin="0,8,0,0">
                        <Button Content="＋ 行追加"
                                Command="{Binding AddRowCommand}"
                                Style="{StaticResource RowOpButtonStyle}" />
                        <Button Content="挿入"
                                Command="{Binding InsertRowCommand}"
                                Style="{StaticResource RowOpButtonStyle}" />
                        <Button Content="🗑 削除"
                                Command="{Binding DeleteRowCommand}"
                                Style="{StaticResource RowOpButtonStyle}" />
                        <Button Content="↑"
                                Command="{Binding MoveUpCommand}"
                                Style="{StaticResource RowOpButtonStyle}" />
                        <Button Content="↓"
                                Command="{Binding MoveDownCommand}"
                                Style="{StaticResource RowOpButtonStyle}" />
                        <TextBlock Text="{Binding Rows.Count, StringFormat={}{0} エントリ}"
                                   FontSize="10" Foreground="#AAAAAA"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0" />
                    </StackPanel>

                    <!-- DataGrid -->
                    <DataGrid x:Name="LooperDataGrid"
                              ItemsSource="{Binding Rows}"
                              SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="False"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="False"
                              GridLinesVisibility="Horizontal"
                              BorderBrush="#DDDDDD" BorderThickness="1"
                              SelectionMode="Single"
                              PreviewMouseDoubleClick="DataGrid_PreviewMouseDoubleClick">
                        <DataGrid.Columns>

                            <!-- Enabled (0/1) -->
                            <DataGridTextColumn Header="有効"
                                                Binding="{Binding Enabled, UpdateSourceTrigger=LostFocus}"
                                                Width="45">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- ScriptPath -->
                            <DataGridTextColumn Header="ScriptPath"
                                                Binding="{Binding ScriptPath, UpdateSourceTrigger=LostFocus}"
                                                Width="*" />

                            <!-- MaxRetry -->
                            <DataGridTextColumn Header="MaxRetry"
                                                Binding="{Binding MaxRetry, UpdateSourceTrigger=LostFocus}"
                                                Width="75">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right" />
                                        <Setter Property="Padding"             Value="0,0,4,0" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- IntervalSec -->
                            <DataGridTextColumn Header="Interval(s)"
                                                Binding="{Binding IntervalSec, UpdateSourceTrigger=LostFocus}"
                                                Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right" />
                                        <Setter Property="Padding"             Value="0,0,4,0" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Condition (ComboBox) -->
                            <DataGridComboBoxColumn Header="Condition"
                                                    SelectedItemBinding="{Binding Condition, UpdateSourceTrigger=LostFocus}"
                                                    ItemsSource="{x:Static models:LooperEntry.AllConditions}"
                                                    Width="100" />

                            <!-- Description -->
                            <DataGridTextColumn Header="Description"
                                                Binding="{Binding Description, UpdateSourceTrigger=LostFocus}"
                                                Width="200" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- ─── 右: ループ設定リファレンス ─── -->
            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#E0E0E0" BorderThickness="1"
                    CornerRadius="4" Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="Script Looper リファレンス"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="#2D2D30"
                                   Margin="0,0,0,4" />
                        <Separator Margin="0,0,0,4" />

                        <!-- Enabled -->
                        <TextBlock Text="Enabled" Style="{StaticResource RefSectionStyle}" />
                        <TextBlock Style="{StaticResource RefBodyStyle}"
                                   Text="有効フラグ&#x0a;1 = 実行対象&#x0a;0 = スキップ" />

                        <!-- ScriptPath -->
                        <TextBlock Text="ScriptPath" Style="{StaticResource RefSectionStyle}" />
                        <TextBlock Style="{StaticResource RefBodyStyle}"
                                   Text="実行するスクリプトのパス&#x0a;&#x0a;(1) fabriqルート相対パス（推奨）&#x0a;  例: modules\standard\network_config\apply_ethernet.ps1&#x0a;&#x0a;(2) 絶対パス&#x0a;  例: C:\Tools\custom_check.ps1&#x0a;&#x0a;💡 セルをダブルクリックで&#x0a;ファイルダイアログを開く" />

                        <!-- MaxRetry -->
                        <TextBlock Text="MaxRetry" Style="{StaticResource RefSectionStyle}" />
                        <TextBlock Style="{StaticResource RefBodyStyle}"
                                   Text="最大実行回数（1以上）&#x0a;無限ループ防止の安全装置&#x0a;  1 = リトライなし&#x0a;  3 = 初回 + リトライ2回" />

                        <!-- IntervalSec -->
                        <TextBlock Text="IntervalSec" Style="{StaticResource RefSectionStyle}" />
                        <TextBlock Style="{StaticResource RefBodyStyle}"
                                   Text="リトライ間隔（秒, 0以上）&#x0a;  0 = 即座にリトライ&#x0a;  5 = 5秒待機後にリトライ&#x0a;NW系処理は 5〜10秒推奨" />

                        <!-- Condition -->
                        <TextBlock Text="Condition" Style="{StaticResource RefSectionStyle}" />
                        <TextBlock Style="{StaticResource RefBodyStyle}"
                                   Text="OnError:&#x0a;  Error時のみリトライ。&#x0a;  Success等で即ループ終了。&#x0a;&#x0a;Always:&#x0a;  結果に関わらずMaxRetry回&#x0a;  まで常に実行。" />

                        <Separator Margin="0,10,0,4" />
                        <TextBlock Text="ショートカット"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="#888888" Margin="0,0,0,2" />
                        <TextBlock Style="{StaticResource RefBodyStyle}"
                                   Text="Ctrl+E: エクスポート&#x0a;Delete: 選択行を削除" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
