<UserControl x:Class="FabriqStudio.Views.DigitalGyotaqEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.InputBindings>
        <KeyBinding Key="E" Modifiers="Control" Command="{Binding ExportCommand}" />
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveCommand}" />
        <KeyBinding Key="Delete" Command="{Binding DeleteTaskCommand}" />
    </UserControl.InputBindings>

    <UserControl.Resources>
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Padding"      Value="12,5" />
            <Setter Property="FontSize"     Value="12" />
            <Setter Property="Cursor"       Value="Hand" />
            <Setter Property="Background"   Value="#F0F0F0" />
            <Setter Property="BorderBrush"  Value="#CCCCCC" />
            <Setter Property="Margin"       Value="0,0,6,0" />
        </Style>
        <Style x:Key="AccentButtonStyle" TargetType="Button"
               BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Background" Value="#007ACC" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style x:Key="RowOpButtonStyle" TargetType="Button">
            <Setter Property="Padding"      Value="10,4" />
            <Setter Property="FontSize"     Value="11" />
            <Setter Property="Cursor"       Value="Hand" />
            <Setter Property="Background"   Value="#F5F5F5" />
            <Setter Property="BorderBrush"  Value="#CCCCCC" />
            <Setter Property="Margin"       Value="0,0,4,0" />
        </Style>
        <Style x:Key="DetailLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#444444" />
            <Setter Property="Margin"     Value="0,10,0,4" />
        </Style>
        <Style x:Key="DetailTextBoxStyle" TargetType="TextBox">
            <Setter Property="FontSize"    Value="12" />
            <Setter Property="Padding"     Value="6,4" />
            <Setter Property="BorderBrush" Value="#CCCCCC" />
        </Style>
    </UserControl.Resources>

    <Grid Background="#F3F3F3">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- ツールバー -->
            <RowDefinition Height="Auto" />  <!-- モジュール名バー -->
            <RowDefinition Height="*" />     <!-- メインコンテンツ -->
        </Grid.RowDefinitions>

        <!-- ===== ツールバー ===== -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                Padding="10,7">
            <DockPanel LastChildFill="False">

                <!-- 左: 操作ボタン -->
                <Button DockPanel.Dock="Left"
                        Content="📄 新規"
                        Command="{Binding NewCommand}"
                        Style="{StaticResource ToolbarButtonStyle}" />
                <Button DockPanel.Dock="Left"
                        Content="📂 読み込み"
                        Command="{Binding LoadCommand}"
                        Style="{StaticResource ToolbarButtonStyle}" />
                <Button DockPanel.Dock="Left"
                        Content="💾 保存"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource ToolbarButtonStyle}" />
                <Button DockPanel.Dock="Left"
                        Content="📤 エクスポート"
                        Command="{Binding ExportCommand}"
                        Style="{StaticResource AccentButtonStyle}" />

                <!-- 右: ステータス / エラー / Dirty インジケータ -->
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding ErrorMessage}"
                           Foreground="Red" FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"
                           Visibility="{Binding ErrorMessage,
                               Converter={StaticResource NullToCollapsedConverter}}" />
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding StatusMessage}"
                           Foreground="#107C10" FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"
                           Visibility="{Binding StatusMessage,
                               Converter={StaticResource NullToCollapsedConverter}}" />
                <TextBlock DockPanel.Dock="Right"
                           Text="● 未保存の変更があります"
                           Foreground="OrangeRed" FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDirty}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </DockPanel>
        </Border>

        <!-- ===== モジュール名バー ===== -->
        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                Padding="12,8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="モジュール名:"
                           FontSize="12" FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <TextBlock DockPanel.Dock="Right"
                           Text="（エクスポート時のフォルダ名・メニュー表示名）"
                           FontSize="10" Foreground="#AAAAAA"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0" />
                <TextBox Text="{Binding ModuleName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="13"
                         Padding="6,4"
                         BorderBrush="#CCCCCC"
                         MaxWidth="320"
                         HorizontalAlignment="Left" />
            </DockPanel>
        </Border>

        <!-- ===== メインコンテンツ: DataGrid + 詳細パネル ===== -->
        <Grid Grid.Row="2" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"   MinWidth="350" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <!-- ─── 左: タスク一覧 DataGrid ─── -->
            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#E0E0E0" BorderThickness="1"
                    CornerRadius="4" Padding="10">
                <DockPanel>

                    <!-- 行操作ボタン (下部) -->
                    <StackPanel DockPanel.Dock="Bottom"
                                Orientation="Horizontal"
                                Margin="0,8,0,0">
                        <Button Content="＋ タスク追加"
                                Command="{Binding AddTaskCommand}"
                                Style="{StaticResource RowOpButtonStyle}" />
                        <Button Content="挿入"
                                Command="{Binding InsertTaskCommand}"
                                Style="{StaticResource RowOpButtonStyle}" />
                        <Button Content="🗑 削除"
                                Command="{Binding DeleteTaskCommand}"
                                Style="{StaticResource RowOpButtonStyle}" />
                        <Button Content="↑"
                                Command="{Binding MoveUpCommand}"
                                Style="{StaticResource RowOpButtonStyle}" />
                        <Button Content="↓"
                                Command="{Binding MoveDownCommand}"
                                Style="{StaticResource RowOpButtonStyle}" />
                        <TextBlock Text="{Binding Tasks.Count, StringFormat={}{0} タスク}"
                                   FontSize="10" Foreground="#AAAAAA"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0" />
                    </StackPanel>

                    <!-- DataGrid -->
                    <DataGrid ItemsSource="{Binding Tasks}"
                              SelectedItem="{Binding SelectedTask, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="False"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="False"
                              GridLinesVisibility="Horizontal"
                              BorderBrush="#DDDDDD" BorderThickness="1"
                              SelectionMode="Single">
                        <DataGrid.Columns>

                            <!-- Enabled (CheckBox) -->
                            <DataGridCheckBoxColumn Header="✓"
                                                     Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="36" />

                            <!-- TaskId (読み取り専用) -->
                            <DataGridTextColumn Header="ID"
                                                Binding="{Binding TaskId, Mode=OneWay}"
                                                Width="52"
                                                IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                        <Setter Property="Foreground"          Value="#888888" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- TaskTitle (読み取り専用 — 詳細パネルで編集) -->
                            <DataGridTextColumn Header="タスクタイトル"
                                                Binding="{Binding TaskTitle, Mode=OneWay}"
                                                Width="*"
                                                IsReadOnly="True" />

                            <!-- OpenCommand (読み取り専用、参考表示) -->
                            <DataGridTextColumn Header="コマンド"
                                                Binding="{Binding OpenCommand, Mode=OneWay}"
                                                Width="140"
                                                IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#666666" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- ─── 右: 選択タスク詳細パネル ─── -->
            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#E0E0E0" BorderThickness="1"
                    CornerRadius="4" Padding="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">

                    <!-- SelectedTask が null の時はプレースホルダーを表示 -->
                    <Grid>
                        <!-- プレースホルダー -->
                        <TextBlock Text="タスクを選択してください"
                                   FontSize="12" Foreground="#AAAAAA"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTask, Converter={StaticResource NullToCollapsedConverter}}"
                                                     Value="Visible">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- 詳細編集フォーム -->
                        <StackPanel DataContext="{Binding SelectedTask}"
                                    Visibility="{Binding DataContext.SelectedTask,
                                        RelativeSource={RelativeSource AncestorType=UserControl},
                                        Converter={StaticResource NullToCollapsedConverter}}">

                            <TextBlock Text="タスク詳細"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="#2D2D30"
                                       Margin="0,0,0,4" />
                            <Separator Margin="0,0,0,2" />

                            <!-- コマンドライブラリから選択 -->
                            <Button Content="📋 コマンドライブラリから選択..."
                                    Command="{Binding DataContext.SelectCommandCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Margin="0,6,0,4"
                                    Padding="10,6"
                                    FontSize="11"
                                    Cursor="Hand"
                                    Background="#F0F0F0"
                                    BorderBrush="#CCCCCC"
                                    HorizontalAlignment="Stretch"
                                    ToolTip="コマンドライブラリから自動起動コマンドを選択します" />

                            <!-- TaskTitle -->
                            <TextBlock Text="タスクタイトル" Style="{StaticResource DetailLabelStyle}" />
                            <TextBox Text="{Binding TaskTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource DetailTextBoxStyle}"
                                     MaxLength="40" />

                            <!-- Instruction -->
                            <TextBlock Text="作業指示" Style="{StaticResource DetailLabelStyle}" />
                            <TextBox Text="{Binding Instruction, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource DetailTextBoxStyle}"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     MinHeight="120"
                                     VerticalScrollBarVisibility="Auto" />

                            <!-- OpenCommand -->
                            <TextBlock Text="自動起動コマンド" Style="{StaticResource DetailLabelStyle}" />
                            <TextBox Text="{Binding OpenCommand, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource DetailTextBoxStyle}" />

                            <!-- OpenArgs -->
                            <TextBlock Text="コマンド引数" Style="{StaticResource DetailLabelStyle}" />
                            <TextBox Text="{Binding OpenArgs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource DetailTextBoxStyle}" />

                        </StackPanel>
                    </Grid>

                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
