<Window x:Class="FabriqStudio.Views.ReportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Report"
        Width="760" Height="560"
        MinWidth="500" MinHeight="320"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#2D2D30">

    <DockPanel LastChildFill="True" Margin="14">

        <!-- ボタン行（下端） -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button x:Name="CopyBtn"
                    Content="クリップボードへコピー"
                    Padding="12,5" FontSize="12" Cursor="Hand"
                    Background="#3E3E42" Foreground="#CCCCCC"
                    BorderThickness="0"
                    Margin="0,0,8,0"
                    Click="CopyBtn_Click" />
            <Button Content="閉じる"
                    Padding="18,5" FontSize="12" Cursor="Hand"
                    Background="#007ACC" Foreground="White"
                    BorderThickness="0"
                    IsDefault="True" IsCancel="True"
                    Click="CloseBtn_Click" />
        </StackPanel>

        <!-- スクロール可能な本文 -->
        <Border Background="#1E1E1E"
                BorderBrush="#3E3E42" BorderThickness="1"
                CornerRadius="3">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Padding="10,8">
                <TextBox x:Name="BodyBox"
                         IsReadOnly="True"
                         Background="Transparent"
                         Foreground="#DDDDDD"
                         BorderThickness="0"
                         FontFamily="Consolas, Cascadia Mono, Consolas"
                         FontSize="12"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Disabled"
                         HorizontalScrollBarVisibility="Disabled"
                         AcceptsReturn="True" />
            </ScrollViewer>
        </Border>
    </DockPanel>
</Window>
