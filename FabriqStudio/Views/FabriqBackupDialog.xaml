<Window x:Class="FabriqStudio.Views.FabriqBackupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="fabriq バックアップ"
        Width="560"
        SizeToContent="Height"
        MinHeight="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#2D2D30">

    <Window.Resources>
        <Style x:Key="DlgButtonStyle" TargetType="Button">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="FontSize"        Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.70" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.35" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="22,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- サマリー -->
        <StackPanel Grid.Row="0">
            <TextBlock x:Name="SummaryText"
                       FontSize="12" Foreground="#CCCCCC"
                       TextWrapping="Wrap" />
        </StackPanel>

        <!-- 出力先親フォルダ -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="出力先の親フォルダ（この下に fabriq_backup_yyyyMMdd_HHmmss/ が作成されます）"
                       FontSize="10" Foreground="#AAAAAA"
                       Margin="0,0,0,4" />
            <DockPanel>
                <Button x:Name="BrowseBtn"
                        DockPanel.Dock="Right"
                        Style="{StaticResource DlgButtonStyle}"
                        Content="参照..."
                        Background="#3E3E42"
                        Foreground="#CCCCCC"
                        Padding="14,6"
                        Margin="8,0,0,0"
                        Click="BrowseBtn_Click" />
                <TextBox x:Name="FolderPathBox"
                         Background="#3C3C3C"
                         Foreground="#FFFFFF"
                         CaretBrush="#FFFFFF"
                         BorderBrush="#555555"
                         BorderThickness="1"
                         Padding="8,6"
                         FontSize="12"
                         IsReadOnly="True" />
            </DockPanel>
        </StackPanel>

        <!-- メモ -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="メモ（USER_MEMO.txt としてバックアップのルートに配置）"
                       FontSize="10" Foreground="#AAAAAA"
                       Margin="0,0,0,4" />
            <TextBox x:Name="MemoBox"
                     Background="#3C3C3C"
                     Foreground="#FFFFFF"
                     CaretBrush="#FFFFFF"
                     BorderBrush="#555555"
                     BorderThickness="1"
                     Padding="8,6"
                     FontSize="12"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     MinHeight="100" MaxHeight="180" />
        </StackPanel>

        <!-- 除外ルール概要 -->
        <Border Grid.Row="6"
                Background="#252526"
                BorderBrush="#3E3E42" BorderThickness="1"
                CornerRadius="3"
                Padding="10,8">
            <StackPanel>
                <TextBlock Text="除外ルール（概要）"
                           FontSize="10" Foreground="#AAAAAA"
                           Margin="0,0,0,4" />
                <TextBlock FontSize="10" Foreground="#888888" TextWrapping="Wrap">
                    ディレクトリ: .git / .claude / dev / logs / apps / commands / evidence / kernel/ps1<LineBreak />
                    拡張子: .ps1 / .bat / .bak / .tmp / .log<LineBreak />
                    ファイル: VERSION / REQUIRES_KERNEL / Guide.txt / preset.csv / CLAUDE.md / CHANGELOG.md / Fabriq.exe など<LineBreak />
                    例外: modules 配下の素材フォルダ (assets/ backup/ source/ 等) は除外ルールを外して丸ごと保存
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ボタン行 -->
        <StackPanel Grid.Row="8"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <Button x:Name="CancelBtn"
                    Style="{StaticResource DlgButtonStyle}"
                    Content="キャンセル"
                    Background="#3E3E42"
                    Foreground="#CCCCCC"
                    Padding="16,6"
                    IsCancel="True"
                    Click="CancelBtn_Click" />

            <Button x:Name="OkBtn"
                    Style="{StaticResource DlgButtonStyle}"
                    Content="バックアップ開始"
                    Background="#00796B"
                    Foreground="#FFFFFF"
                    Padding="16,6"
                    Margin="8,0,0,0"
                    IsDefault="True"
                    IsEnabled="False"
                    Click="OkBtn_Click" />
        </StackPanel>
    </Grid>
</Window>
