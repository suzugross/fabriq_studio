<Window x:Class="FabriqStudio.Views.PianistListEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="pianist_list.csv 編集"
        Width="760" Height="540"
        MinWidth="620" MinHeight="420"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#F5F5F5">

    <Window.Resources>
        <Style x:Key="DlgButtonStyle" TargetType="Button">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="FontSize"        Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.70" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.35" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel Margin="14">

        <!-- ===== Top: subtitle (file path) ===== -->
        <TextBlock DockPanel.Dock="Top"
                   Text="modules/extended/pianist/pianist_list.csv"
                   FontSize="11"
                   Foreground="#888888"
                   Margin="0,0,0,10" />

        <!-- ===== Add row toolbar ===== -->
        <!-- ヒント文を別行に分離して TextWrapping=Wrap、ウィンドウ幅にかかわらず見切れないようにする -->
        <Border DockPanel.Dock="Top"
                Padding="0,0,0,10">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="行追加:"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               FontSize="12"
                               Foreground="#444444" />
                    <ComboBox x:Name="ProfileCombo"
                              ItemsSource="{Binding AvailableProfiles}"
                              Width="260"
                              FontSize="12"
                              Padding="6,4"
                              Background="#FFFFFF"
                              Foreground="#222222"
                              BorderBrush="#BBBBBB"
                              ToolTip="profiles/ に実在しかつ pianist_list.csv に未登録のプロファイル" />
                    <Button x:Name="AddBtn"
                            Style="{StaticResource DlgButtonStyle}"
                            Content="+ 追加"
                            Background="#107C10"
                            Foreground="#FFFFFF"
                            Padding="14,5"
                            Margin="8,0,0,0"
                            Click="AddBtn_Click" />
                </StackPanel>
                <TextBlock x:Name="EmptyHint"
                           Margin="0,6,0,0"
                           FontSize="11"
                           Foreground="#888888"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"
                           Text="（追加できるプロファイルがありません — profiles/ 配下の全 profile が登録済みです）" />
            </StackPanel>
        </Border>

        <!-- ===== Bottom: warning + buttons ===== -->
        <Border DockPanel.Dock="Bottom" Padding="0,10,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14"   />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        x:Name="WarnBar"
                        Padding="10,6"
                        Background="#FFF4D8"
                        BorderBrush="#E0C176"
                        BorderThickness="1"
                        CornerRadius="4"
                        Visibility="Collapsed">
                    <TextBlock x:Name="WarnText"
                               FontSize="11"
                               Foreground="#7A5A1A"
                               TextWrapping="Wrap" />
                </Border>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="CancelBtn"
                            Style="{StaticResource DlgButtonStyle}"
                            Content="キャンセル"
                            Background="#E0E0E0"
                            Foreground="#333333"
                            Padding="16,6"
                            IsCancel="True"
                            Click="CancelBtn_Click" />
                    <Button x:Name="OkBtn"
                            Style="{StaticResource DlgButtonStyle}"
                            Content="保存して閉じる"
                            Background="#007ACC"
                            Foreground="#FFFFFF"
                            Padding="16,6"
                            Margin="8,0,0,0"
                            IsDefault="True"
                            Click="OkBtn_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== Center: entries grid ===== -->
        <DataGrid x:Name="EntriesGrid"
                  ItemsSource="{Binding Entries}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  CanUserResizeRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="All"
                  HorizontalGridLinesBrush="#EEEEEE"
                  VerticalGridLinesBrush="#EEEEEE"
                  RowHeight="28"
                  FontSize="12"
                  Background="#FFFFFF"
                  BorderBrush="#CCCCCC"
                  BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="" Width="36" CanUserSort="False" CanUserResize="False" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="🗑"
                                    Padding="2,0"
                                    Margin="2"
                                    FontSize="11"
                                    Cursor="Hand"
                                    ToolTip="この行を削除"
                                    Click="DeleteRow_Click" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="✓ Enabled" Width="80" CanUserSort="False" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="ProfileName"
                                    Binding="{Binding ProfileName}"
                                    Width="200"
                                    IsReadOnly="True" />

                <DataGridTextColumn Header="Group"
                                    Binding="{Binding Group, UpdateSourceTrigger=PropertyChanged}"
                                    Width="120" />

                <DataGridTextColumn Header="Description"
                                    Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                    Width="*" />

                <DataGridTextColumn Header="Segment"
                                    Binding="{Binding Segment, UpdateSourceTrigger=PropertyChanged}"
                                    Width="160" />
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</Window>
