<Window x:Class="FabriqStudio.Views.RegistryPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="レジストリ辞書から選択"
        Width="720" Height="520"
        MinWidth="600" MinHeight="400"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#2D2D30">

    <Window.Resources>
        <Style x:Key="DlgButtonStyle" TargetType="Button">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="FontSize"        Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.70" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.35" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterComboStyle" TargetType="ComboBox">
            <Setter Property="Background"      Value="#3C3C3C" />
            <Setter Property="Foreground"       Value="#FFFFFF" />
            <Setter Property="BorderBrush"      Value="#555555" />
            <Setter Property="BorderThickness"  Value="1" />
            <Setter Property="Padding"          Value="6,4" />
            <Setter Property="FontSize"         Value="12" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="16,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Row 0: フィルタ行 -->
            <RowDefinition Height="10" />
            <RowDefinition Height="*" />      <!-- Row 2: リスト + プレビュー -->
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />   <!-- Row 4: ボタン行 -->
        </Grid.RowDefinitions>

        <!-- ═══ Row 0: フィルタ ═══ -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- 検索 -->
            <TextBox Grid.Column="0"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Background="#3C3C3C" Foreground="#FFFFFF"
                     CaretBrush="#FFFFFF" BorderBrush="#555555"
                     BorderThickness="1" Padding="8,5" FontSize="12">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="  🔍 検索..." FontSize="12"
                                                           Foreground="#888888" Margin="6,0,0,0" />
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <!-- カテゴリ -->
            <ComboBox Grid.Column="2"
                      Style="{StaticResource FilterComboStyle}"
                      ItemsSource="{Binding CategoryOptions}"
                      SelectedItem="{Binding CategoryFilter}"
                      MinWidth="120" />

            <!-- Hive -->
            <ComboBox Grid.Column="4"
                      Style="{StaticResource FilterComboStyle}"
                      ItemsSource="{Binding HiveOptions}"
                      SelectedItem="{Binding HiveFilter}"
                      IsEnabled="{Binding IsHiveSelectorEnabled}"
                      MinWidth="90" />
        </Grid>

        <!-- ═══ Row 2: リスト + プレビュー ═══ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 左: エントリ一覧 -->
            <ListBox Grid.Column="0"
                     ItemsSource="{Binding FilteredEntries}"
                     SelectedItem="{Binding SelectedEntry}"
                     Background="#252526" Foreground="#CCCCCC"
                     BorderBrush="#3F3F46" BorderThickness="1"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4,3">
                            <TextBlock Text="{Binding Title}"
                                       FontSize="12" Foreground="#FFFFFF"
                                       TextTrimming="CharacterEllipsis" />
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="{Binding Hive}"
                                           FontSize="10" Foreground="#569CD6"
                                           Margin="0,0,8,0" />
                                <TextBlock Text="{Binding KeyName}"
                                           FontSize="10" Foreground="#888888"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- 右: 読み取り専用プレビュー -->
            <Border Grid.Column="2"
                    Background="#1E1E1E" BorderBrush="#3F3F46" BorderThickness="1"
                    CornerRadius="2" Padding="14,10">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel DataContext="{Binding SelectedEntry}"
                                Visibility="{Binding DataContext.HasSelection,
                                    RelativeSource={RelativeSource AncestorType=Window},
                                    Converter={StaticResource BoolToVisibilityConverter}}">

                        <!-- Title -->
                        <TextBlock Text="Title" FontSize="10" Foreground="#666666" Margin="0,0,0,2" />
                        <TextBlock Text="{Binding Title}" FontSize="13" Foreground="#FFFFFF"
                                   TextWrapping="Wrap" Margin="0,0,0,10" />

                        <!-- Hive -->
                        <TextBlock Text="Hive" FontSize="10" Foreground="#666666" Margin="0,0,0,2" />
                        <TextBlock Text="{Binding Hive}" FontSize="12" Foreground="#569CD6"
                                   Margin="0,0,0,10" />

                        <!-- KeyPath -->
                        <TextBlock Text="KeyPath" FontSize="10" Foreground="#666666" Margin="0,0,0,2" />
                        <TextBlock Text="{Binding KeyPath}" FontSize="11" Foreground="#CCCCCC"
                                   TextWrapping="Wrap" Margin="0,0,0,10" />

                        <!-- KeyName -->
                        <TextBlock Text="KeyName" FontSize="10" Foreground="#666666" Margin="0,0,0,2" />
                        <TextBlock Text="{Binding KeyName}" FontSize="12" Foreground="#CCCCCC"
                                   Margin="0,0,0,10" />

                        <!-- Type -->
                        <TextBlock Text="Type" FontSize="10" Foreground="#666666" Margin="0,0,0,2" />
                        <TextBlock Text="{Binding Type}" FontSize="12" Foreground="#CCCCCC"
                                   Margin="0,0,0,10" />

                        <!-- Value -->
                        <TextBlock Text="Value" FontSize="10" Foreground="#666666" Margin="0,0,0,2" />
                        <TextBlock Text="{Binding Value}" FontSize="12" Foreground="#DCDCAA"
                                   TextWrapping="Wrap" Margin="0,0,0,10" />

                        <!-- Description -->
                        <TextBlock Text="Description" FontSize="10" Foreground="#666666" Margin="0,0,0,2" />
                        <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#999999"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ═══ Row 4: ボタン ═══ -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <Button x:Name="CancelBtn"
                    Style="{StaticResource DlgButtonStyle}"
                    Content="キャンセル"
                    Background="#3E3E42" Foreground="#CCCCCC"
                    Padding="16,7"
                    IsCancel="True"
                    Click="CancelBtn_Click" />

            <Button x:Name="SelectBtn"
                    Style="{StaticResource DlgButtonStyle}"
                    Content="選択して追加"
                    Background="#007ACC" Foreground="#FFFFFF"
                    Padding="16,7" Margin="8,0,0,0"
                    IsDefault="True"
                    IsEnabled="{Binding HasSelection}"
                    Click="SelectBtn_Click" />
        </StackPanel>
    </Grid>
</Window>
