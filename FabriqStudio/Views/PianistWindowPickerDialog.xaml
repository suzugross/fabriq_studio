<Window x:Class="FabriqStudio.Views.PianistWindowPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ウィンドウを選択"
        Width="640" Height="520"
        MinWidth="520" MinHeight="400"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#F5F5F5">

    <Window.Resources>
        <Style x:Key="DlgButtonStyle" TargetType="Button">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="FontSize"        Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.70" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.35" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource DlgButtonStyle}">
            <Setter Property="Background" Value="#E8E8E8" />
            <Setter Property="Foreground" Value="#222222" />
            <Setter Property="Padding"    Value="12,5" />
            <Setter Property="FontSize"   Value="12" />
        </Style>
    </Window.Resources>

    <DockPanel Margin="14">

        <!-- ===== Top toolbar ===== -->
        <Border DockPanel.Dock="Top"
                Padding="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="RefreshBtn"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Content="🔄 更新"
                        Click="RefreshBtn_Click" />
                <Button x:Name="CountdownBtn"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Content="⏱ 5 秒待ってから取得"
                        Margin="8,0,0,0"
                        Click="CountdownBtn_Click"
                        ToolTip="ダイアログを最小化して 5 秒間待機後にウィンドウ一覧を再取得します（Win+R 等のダイアログ捕捉用）" />
                <CheckBox x:Name="HideNoiseCheck"
                          Content="ノイズを隠す"
                          IsChecked="True"
                          Foreground="#444444"
                          VerticalAlignment="Center"
                          Margin="14,0,0,0"
                          Checked="HideNoiseCheck_Changed"
                          Unchecked="HideNoiseCheck_Changed" />
                <TextBlock x:Name="CountdownLabel"
                           VerticalAlignment="Center"
                           Margin="14,0,0,0"
                           FontSize="12"
                           Foreground="#A05B00" />
            </StackPanel>
        </Border>

        <!-- ===== Bottom: candidate + buttons ===== -->
        <Border DockPanel.Dock="Bottom" Padding="0,10,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6"    />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14"   />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           x:Name="SelectionLabel"
                           FontSize="11"
                           Foreground="#666666"
                           Text="選択中: （未選択）"
                           TextTrimming="CharacterEllipsis" />

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*"    />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="挿入する文字列:"
                               FontSize="12"
                               Foreground="#444444"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <ComboBox Grid.Column="1"
                              x:Name="CandidateCombo"
                              IsEditable="True"
                              FontSize="13"
                              Padding="6,4"
                              Background="#FFFFFF"
                              Foreground="#222222"
                              BorderBrush="#BBBBBB"
                              ToolTip="フルタイトル / 区切り記号で分割した候補。自由編集も可。" />
                </Grid>

                <StackPanel Grid.Row="4"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="CancelBtn"
                            Style="{StaticResource DlgButtonStyle}"
                            Content="キャンセル"
                            Background="#E0E0E0"
                            Foreground="#333333"
                            Padding="16,6"
                            IsCancel="True"
                            Click="CancelBtn_Click" />
                    <Button x:Name="OkBtn"
                            Style="{StaticResource DlgButtonStyle}"
                            Content="挿入して閉じる"
                            Background="#007ACC"
                            Foreground="#FFFFFF"
                            Padding="16,6"
                            Margin="8,0,0,0"
                            IsDefault="True"
                            Click="OkBtn_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== Center: window list ===== -->
        <DataGrid x:Name="WindowsGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  CanUserResizeRows="False"
                  CanUserSortColumns="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#EEEEEE"
                  IsReadOnly="True"
                  RowHeight="24"
                  FontSize="12"
                  Background="#FFFFFF"
                  BorderBrush="#CCCCCC"
                  BorderThickness="1"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  EnableRowVirtualization="True"
                  SelectionChanged="WindowsGrid_SelectionChanged"
                  MouseDoubleClick="WindowsGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="タイトル"
                                    Binding="{Binding Title}"
                                    Width="*"
                                    SortMemberPath="Title" />
                <DataGridTextColumn Header="プロセス"
                                    Binding="{Binding ProcessName}"
                                    Width="160"
                                    SortMemberPath="ProcessName" />
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</Window>
