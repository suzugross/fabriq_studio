<Window x:Class="FabriqStudio.Views.PassphraseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="マスターパスフレーズ設定"
        Width="420"
        SizeToContent="Height"
        MinHeight="180"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#2D2D30">

    <Window.Resources>
        <Style x:Key="DlgButtonStyle" TargetType="Button">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="FontSize"        Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.70" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="22,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ステータス表示 -->
        <StackPanel Grid.Row="0">
            <TextBlock x:Name="StatusText"
                       FontSize="11" Foreground="#AAAAAA"
                       TextWrapping="Wrap" />
        </StackPanel>

        <!-- パスフレーズ入力 -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="パスフレーズ"
                       FontSize="10" Foreground="#666666"
                       Margin="0,0,0,5" />
            <PasswordBox x:Name="PassphraseBox"
                         Background="#3C3C3C"
                         Foreground="#FFFFFF"
                         CaretBrush="#FFFFFF"
                         BorderBrush="#555555"
                         BorderThickness="1"
                         Padding="8,6"
                         FontSize="13"
                         PasswordChanged="PassphraseBox_PasswordChanged" />
            <TextBlock Text="空のまま設定するとパスフレーズをクリアします"
                       FontSize="9" Foreground="#555555"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- ボタン行 -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <Button x:Name="CancelBtn"
                    Style="{StaticResource DlgButtonStyle}"
                    Content="キャンセル"
                    Background="#3E3E42"
                    Foreground="#CCCCCC"
                    Padding="16,6"
                    IsCancel="True"
                    Click="CancelBtn_Click" />

            <Button x:Name="OkBtn"
                    Style="{StaticResource DlgButtonStyle}"
                    Content="設定"
                    Background="#007ACC"
                    Foreground="#FFFFFF"
                    Padding="16,6"
                    Margin="8,0,0,0"
                    IsDefault="True"
                    Click="OkBtn_Click" />
        </StackPanel>
    </Grid>
</Window>
