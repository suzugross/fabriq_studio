<UserControl x:Class="FabriqStudio.Views.WelcomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="AccentButtonStyle" TargetType="Button">
            <Setter Property="Background"   Value="#007ACC" />
            <Setter Property="Foreground"   Value="#FFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"      Value="24,10" />
            <Setter Property="FontSize"     Value="14" />
            <Setter Property="Cursor"       Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1A9EE0" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#005FA0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- 右ペイン全体をダークで塗りつぶしてウェルカム画面を表示 -->
    <Grid Background="#1E1E1E">
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="420">

            <!-- アイコン -->
            <TextBlock Text="⚙"
                       FontSize="52"
                       HorizontalAlignment="Center"
                       Foreground="#007ACC"
                       Margin="0,0,0,20" />

            <!-- タイトル -->
            <TextBlock Text="fabriq studio"
                       FontSize="28" FontWeight="Bold"
                       Foreground="#FFFFFF"
                       HorizontalAlignment="Center" />

            <TextBlock Text="管理ツール"
                       FontSize="13"
                       Foreground="#777777"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,40" />

            <!-- 説明文 -->
            <TextBlock Text="fabriq のルートフォルダを選択してください。"
                       FontSize="14"
                       Foreground="#CCCCCC"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,6" />

            <TextBlock Text="（kernel/ と modules/ を含むフォルダが対象です）"
                       FontSize="11"
                       Foreground="#555555"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,28" />

            <!-- フォルダ選択ボタン -->
            <Button Content="📂  フォルダを選択..."
                    Style="{StaticResource AccentButtonStyle}"
                    Command="{Binding SelectFolderCommand}"
                    HorizontalAlignment="Center" />

            <!-- エラーメッセージ -->
            <Border Margin="0,20,0,0"
                    Padding="14,10"
                    Background="#3A0000"
                    CornerRadius="4"
                    Visibility="{Binding ErrorMessage,
                                 Converter={StaticResource NullToCollapsedConverter}}">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#FF7070"
                           FontSize="12"
                           TextWrapping="Wrap"
                           TextAlignment="Center" />
            </Border>

        </StackPanel>
    </Grid>
</UserControl>
