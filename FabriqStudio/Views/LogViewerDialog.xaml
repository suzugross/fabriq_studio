<Window x:Class="FabriqStudio.Views.LogViewerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="800" Height="600"
        MinWidth="480" MinHeight="320"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ログ表示エリア -->
        <TextBox x:Name="LogTextBox"
                 Grid.Row="0"
                 IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="12"
                 Background="#1E1E1E"
                 Foreground="#DCDCDC"
                 Padding="10"
                 BorderBrush="#555555"
                 TextWrapping="NoWrap"
                 AcceptsReturn="True" />

        <!-- ボタンエリア -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="クリップボードにコピー"
                    Click="CopyToClipboard_Click"
                    Padding="16,6"
                    Margin="0,0,8,0"
                    Cursor="Hand" />
            <Button Content="閉じる"
                    Click="Close_Click"
                    Padding="16,6"
                    IsDefault="True"
                    IsCancel="True"
                    Cursor="Hand" />
        </StackPanel>
    </Grid>
</Window>
