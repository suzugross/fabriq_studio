<UserControl x:Class="FabriqStudio.Views.PrinterDriverDetectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="SectionBorderStyle" TargetType="Border">
            <Setter Property="Background"      Value="White" />
            <Setter Property="BorderBrush"     Value="#E0E0E0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius"    Value="4" />
            <Setter Property="Padding"         Value="12" />
        </Style>
    </UserControl.Resources>

    <Grid Background="#F3F3F3">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- ヘッダー -->
            <RowDefinition Height="Auto" />  <!-- スキャン入力行 -->
            <RowDefinition Height="*" />     <!-- 結果テーブル -->
        </Grid.RowDefinitions>

        <!-- ===== ヘッダー ===== -->
        <StackPanel Grid.Row="0" Margin="16,16,16,8">
            <TextBlock Text="🖨  プリンタドライバ検出"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#2D2D30" />
            <TextBlock FontSize="11" Foreground="#666666" Margin="0,4,0,0"
                       TextWrapping="Wrap">
                <Run Text="指定フォルダ配下の INF ファイルをスキャンし、" />
                <Run Text="プリンタドライバ名（INF 内モデル名）を抽出します。" />
                <LineBreak />
                <Run Text="抽出された DriverName は fabriq の " />
                <Run FontFamily="Consolas" Foreground="#5C2D91" Text="hostlist.csv" />
                <Run Text=" / " />
                <Run FontFamily="Consolas" Foreground="#5C2D91" Text="printer_driver_list.csv" />
                <Run Text=" にそのまま転記できます。" />
            </TextBlock>
        </StackPanel>

        <!-- ===== スキャン入力行 ===== -->
        <Border Grid.Row="1" Style="{StaticResource SectionBorderStyle}"
                Margin="16,0,16,8">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="スキャン先:"
                               FontSize="12" Foreground="#555555"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />

                    <TextBox Grid.Column="1"
                             Text="{Binding ScanPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="12" Padding="6,5"
                             VerticalContentAlignment="Center"
                             BorderBrush="#CCCCCC" />

                    <Button Grid.Column="2"
                            Content="📂 選択"
                            Command="{Binding BrowseCommand}"
                            Padding="10,5" FontSize="12" Cursor="Hand"
                            Margin="6,0,0,0" />

                    <Button Grid.Column="3"
                            Content="🔄 スキャン"
                            Command="{Binding ScanCommand}"
                            Background="#007ACC" Foreground="White"
                            BorderThickness="0"
                            Padding="14,5" FontSize="12" Cursor="Hand"
                            Margin="6,0,0,0" />
                </Grid>

                <!-- オプション行: 自動展開チェック -->
                <CheckBox Content="📦 EXE/ZIP を自動展開（workspace の tools/7z.exe を使用。無ければ ZIP は組込みで展開）"
                          IsChecked="{Binding AutoExtractArchives, Mode=TwoWay}"
                          FontSize="11" Foreground="#555555"
                          Margin="0,8,0,0"
                          VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- ===== 結果テーブル ===== -->
        <Border Grid.Row="2" Style="{StaticResource SectionBorderStyle}"
                Margin="16,0,16,16">
            <DockPanel>

                <!-- ステータスバー -->
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8" LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left"
                               Text="{Binding StatusMessage}"
                               FontSize="11" Foreground="#107C10"
                               VerticalAlignment="Center"
                               Visibility="{Binding StatusMessage,
                                   Converter={StaticResource NullToCollapsedConverter}}" />

                    <TextBlock DockPanel.Dock="Left"
                               Text="{Binding ErrorMessage}"
                               FontSize="11" Foreground="Red"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Visibility="{Binding ErrorMessage,
                                   Converter={StaticResource NullToCollapsedConverter}}" />

                    <TextBlock DockPanel.Dock="Left"
                               Text="スキャン中..."
                               FontSize="11" Foreground="#888888"
                               VerticalAlignment="Center"
                               Visibility="{Binding IsScanning,
                                   Converter={StaticResource BoolToVisibilityConverter}}" />

                    <!-- 右: 選択行を printer_driver_list.csv にエクスポート / クリップボードへコピー -->
                    <Button DockPanel.Dock="Right"
                            Content="➕ printer_driver_list.csv に追加"
                            Command="{Binding ExportCommand}"
                            ToolTip="選択行の DriverName を workspace の printer_driver_list.csv に追記します"
                            Padding="10,4" FontSize="11" Cursor="Hand"
                            Background="#107C10" Foreground="White"
                            BorderThickness="0" />
                    <Button DockPanel.Dock="Right"
                            Content="📋 DriverName をコピー"
                            Command="{Binding CopyDriverNameCommand}"
                            Padding="10,4" FontSize="11" Cursor="Hand"
                            Margin="0,0,6,0" />
                </DockPanel>

                <!-- ドライバ一覧 -->
                <DataGrid ItemsSource="{Binding Drivers}"
                          SelectedItem="{Binding SelectedDriver, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserReorderColumns="False"
                          CanUserResizeColumns="True"
                          CanUserSortColumns="True"
                          GridLinesVisibility="Horizontal"
                          AlternatingRowBackground="#F7F7F7"
                          BorderBrush="#DDDDDD" BorderThickness="1"
                          SelectionMode="Single">
                    <!-- フォーカスに依存せず選択行を強調（D&D 対応画面と同方針） -->
                    <DataGrid.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"                      Color="#3399FF" />
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"     Color="#3399FF" />
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"                  Color="White"   />
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White"   />
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="DriverName"
                                            Binding="{Binding DriverName}"
                                            Width="*" />
                        <DataGridTextColumn Header="フォルダ"
                                            Binding="{Binding FolderName}"
                                            Width="200" />
                        <DataGridTextColumn Header="INF"
                                            Binding="{Binding InfFileName}"
                                            Width="140" />
                        <DataGridTextColumn Header="Arch"
                                            Binding="{Binding Architecture}"
                                            Width="70" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
